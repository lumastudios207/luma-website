---
import PageLayout from '../layouts/PageLayout.astro';
import { icons } from '../components/icons/icons';

const RECAPTCHA_SITE_KEY = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY ?? '6Led6ogsAAAAAFaFaM50DpZNy4glFZvN8fH-5yEX';

const plans = [
  { slug: 'starter',    name: 'Starter',    hours: 10, price: 950,   fit: 'Best for solo founders and early-stage startups' },
  { slug: 'growth',     name: 'Growth',     hours: 20, price: 1800,  fit: 'Best for growing small businesses' },
  { slug: 'scale',      name: 'Scale',      hours: 30, price: 2550,  fit: 'Best for established teams with steady design needs' },
  { slug: 'enterprise', name: 'Enterprise', hours: 40, price: 3200,  fit: 'Best for high-volume marketing teams and agencies' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'Design Subscriptions — Luma Studios',
      description: 'Weekly design subscriptions for businesses that need consistent marketing design without hiring a full-time team.',
      url: 'https://lumastudios.co/pricing/',
      provider: {
        '@type': 'ProfessionalService',
        name: 'Luma Studios',
        url: 'https://lumastudios.co',
      },
      offers: plans.map((p) => ({
        '@type': 'Offer',
        name: `${p.name} — ${p.hours} hours per week`,
        price: p.price,
        priceCurrency: 'USD',
        description: p.fit,
        url: `https://lumastudios.co/pricing/?plan=${p.slug}`,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lumastudios.co/' },
        { '@type': 'ListItem', position: 2, name: 'Pricing', item: 'https://lumastudios.co/pricing/' },
      ],
    },
  ],
};
---

<PageLayout
  title="Design Subscriptions & Pricing | Luma Studios"
  description="Flat-weekly design subscriptions from $950/week. A dedicated design team, unlimited projects in your queue, and the ability to scale up, down, or cancel on 5 business days' notice."
  canonicalUrl="https://lumastudios.co/pricing/"
  ogUrl="https://lumastudios.co/pricing/"
  headerVariant="pricing"
  {jsonLd}
>

<!-- ===================== BREADCRUMB ===================== -->
<div class="breadcrumb_wrap">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="/" class="breadcrumb__link">Home</a></li>
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">Pricing</li>
      </ol>
    </nav>
  </div>
</div>

<!-- ===================== HERO ===================== -->
<section class="home_first pricing_hero" first-load-delay>
  <div class="container">
    <div class="wrap_hom_infr relative z_1 text-center">
      <div class="cube_border"></div>
      <div class="cube_border_2"></div>
      <div class="info_blk_home">
        <h1 class="heading_home pricing_hero_h1">Design subscriptions built to <span class="blue_color">scale with your business</span></h1>
        <div class="descr_home_fir">
          One flat weekly rate. A dedicated design team. Unlimited projects in your queue.
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== PRICING TIERS ===================== -->
<section class="pricing_plans dark_bg overflow-hidden" id="plans">
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center" data-show-down>Subscription Plans</h2>
      <div class="description_section text-center" data-show-down>
        All plans include the full service menu. Scale up, down, or cancel with 5 business days&rsquo; notice.
      </div>
    </div>

    <div class="plan_grid" data-show-down>
      {plans.map((plan) => (
        <div class="plan_card">
          <div class="plan_card__name">{plan.name}</div>
          <div class="plan_card__hours">{plan.hours} hours / week</div>
          <div class="plan_card__price">
            <span class="plan_card__amount">${plan.price.toLocaleString()}</span>
            <span class="plan_card__period">/ week</span>
          </div>
          <div class="plan_card__fit">{plan.fit}</div>
          <button type="button" class="btn_anim outline plan_card__cta" data-plan={plan.slug}>
            <span class="default_btn_bg"></span>
            <span class="cb-btn_cta-title"><span data-text="Get Started">Get Started</span></span>
            <span class="cb-btn_cta-ripple"><span style="background-color: #FFFC10;"></span></span>
          </button>
        </div>
      ))}
    </div>

    <p class="plan_grid__note text-center">
      All plans include the full service menu. Scale up, down, or cancel with 5 business days&rsquo; notice.
    </p>
  </div>
</section>

<!-- ===================== HOW IT WORKS ===================== -->
<section class="pricing_how overflow-hidden">
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center" data-show-down>How It Works</h2>
    </div>
    <div class="wrap_why_work grid grid-cols-3" style="--cols:3;">
      <div class="item_why_work text-center" data-show-down data-delay=".1">
        <div class="icon_why_work"><img src="/img/icons/why_work_2.svg" alt="" loading="lazy"></div>
        <div class="title_why_work">Pick Your Weekly Hours</div>
        <div class="descr_why_work">Choose the allotment that matches your workload — Starter, Growth, Scale, or Enterprise.</div>
      </div>
      <div class="item_why_work text-center" data-show-down data-delay=".15">
        <div class="icon_why_work"><img src="/img/icons/why_work_3.svg" alt="" loading="lazy"></div>
        <div class="title_why_work">Submit Projects to Asana</div>
        <div class="descr_why_work">Drop as many requests as you&rsquo;d like into your shared board. We work through them in priority order you set.</div>
      </div>
      <div class="item_why_work text-center" data-show-down data-delay=".2">
        <div class="icon_why_work"><img src="/img/icons/why_work_6.svg" alt="" loading="lazy"></div>
        <div class="title_why_work">Scale Up, Down, or Pause</div>
        <div class="descr_why_work">Adjust your plan anytime. Cancel with 5 business days&rsquo; written notice. No long-term contract.</div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== SERVICE MENU ===================== -->
<section class="pricing_menu dark_bg overflow-hidden">
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center" data-show-down>Service Menu</h2>
      <div class="description_section text-center" data-show-down>
        A full set of marketing design deliverables — available through any subscription tier.
      </div>
    </div>
    <div class="menu_services_grid grid grid-cols-3" data-show-down>
      <a href="#contact" class="menu_service_card" data-scroll-to>
        <div class="menu_service_card__name">Landing Pages</div>
        <div class="menu_service_card__desc">Focused, conversion-oriented pages built to turn campaign traffic into real leads.</div>
        <span class="menu_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="#contact" class="menu_service_card" data-scroll-to>
        <div class="menu_service_card__name">Ad Creative</div>
        <div class="menu_service_card__desc">Paid-media assets across display, social, and programmatic — on-brand and built to test.</div>
        <span class="menu_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="#contact" class="menu_service_card" data-scroll-to>
        <div class="menu_service_card__name">Sales Collateral</div>
        <div class="menu_service_card__desc">Brochures, one-pagers, and pitch materials designed to help your team close deals.</div>
        <span class="menu_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="#contact" class="menu_service_card" data-scroll-to>
        <div class="menu_service_card__name">Brand Identity</div>
        <div class="menu_service_card__desc">Logos, color systems, typography, and guidelines that give your business a cohesive visual language.</div>
        <span class="menu_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="#contact" class="menu_service_card" data-scroll-to>
        <div class="menu_service_card__name">Social Media Assets</div>
        <div class="menu_service_card__desc">Branded graphics and reusable templates for recurring posts, campaigns, and launches.</div>
        <span class="menu_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="#contact" class="menu_service_card" data-scroll-to>
        <div class="menu_service_card__name">Presentations</div>
        <div class="menu_service_card__desc">Sharp investor, sales, and internal decks designed around your story — not a stock template.</div>
        <span class="menu_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="#contact" class="menu_service_card" data-scroll-to>
        <div class="menu_service_card__name">Custom Illustrations &amp; Iconography</div>
        <div class="menu_service_card__desc">Bespoke illustrations and icon sets that bring your product, content, and marketing to life.</div>
        <span class="menu_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="#contact" class="menu_service_card" data-scroll-to>
        <div class="menu_service_card__name">Event &amp; Print Materials</div>
        <div class="menu_service_card__desc">Booth graphics, conference signage, billboards, and printed collateral — production-ready files included.</div>
        <span class="menu_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="#contact" class="menu_service_card" data-scroll-to>
        <div class="menu_service_card__name">Infographics</div>
        <div class="menu_service_card__desc">Clear, on-brand visuals that turn data, processes, and reports into content people actually read.</div>
        <span class="menu_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
    </div>
  </div>
</section>

<!-- ===================== CONTACT FORM ===================== -->
<section class="pricing_contact overflow-hidden" id="contact">
  <div class="container">
    <div class="pricing_contact__inner">
      <div class="headint_sec">
        <h2 class="title_section text-center" data-show-down>Get In Touch</h2>
        <div class="description_section text-center" data-show-down>
          Tell us a bit about your business and the plan you&rsquo;re interested in. We&rsquo;ll follow up to get you set up.
        </div>
      </div>

      <div class="pricing_form_wrap" data-show-down>
        <img src="/img/cube_3d.webp" alt="" class="pricing_form_cube" width="80" loading="lazy" aria-hidden="true">
        <div id="pricing_form_container">
          <form id="pricing_form_el" novalidate>
            <div class="row_form_inp grid grid-cols-2">
              <div class="form_group">
                <input type="text" placeholder="Your Name" name="name" class="name form_control" autocomplete="name">
                <small class="error_message"></small>
                <span class="underline_inp"></span>
              </div>
              <div class="form_group">
                <input type="text" placeholder="Company Name" name="company" class="company form_control" autocomplete="organization">
                <small class="error_message"></small>
                <span class="underline_inp"></span>
              </div>
            </div>
            <div class="row_form_inp grid grid-cols-2">
              <div class="form_group">
                <input type="tel" placeholder="Phone" name="phone" class="phone form_control" autocomplete="tel">
                <small class="error_message"></small>
                <span class="underline_inp"></span>
              </div>
              <div class="form_group">
                <input type="text" placeholder="Website URL" name="website" class="website form_control" autocomplete="url">
                <small class="error_message"></small>
                <span class="underline_inp"></span>
              </div>
            </div>
            <div class="row_form_inp">
              <div class="form_group form_group--select">
                <select name="plan" class="plan form_control" id="pricing_plan_select">
                  {plans.map((plan) => (
                    <option value={plan.slug}>{plan.name} — {plan.hours} hrs/week — ${plan.price.toLocaleString()}/week</option>
                  ))}
                </select>
                <small class="error_message"></small>
                <span class="underline_inp"></span>
              </div>
            </div>
            <div class="footer_form">
              <div class="flex items-center justify-end">
                <button type="submit" class="btn_anim submit_form_page">
                  <span class="default_btn_bg"></span>
                  <span class="cb-btn_cta-title"><span data-text="Send Message">Send Message</span></span>
                  <span class="cb-btn_cta-ripple"><span style="background-color: #212121;"></span></span>
                </button>
              </div>
            </div>
          </form>
        </div>
        <div class="contact_thanks hidden" id="pricing_form_thanks">
          <div class="thansk_wrapp_go">
            <div class="decor_top_sg">
              <img src="/img/triangle.webp" alt="" width="70" loading="lazy">
            </div>
            <div class="subtitle_formgg">Thank you!</div>
            <div class="item_tzg">Your request has been received. We&rsquo;ll review your details and get back to you within one business day.</div>
            <div class="item_tzg">Keep an eye on your inbox — and check your spam folder if you don&rsquo;t hear from us.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== FAQ ===================== -->
<section class="pricing_faq dark_bg overflow-hidden">
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center">Subscription Services FAQs</h2>
    </div>
    <div class="wrap_faqs mx-auto js-accordion">
      <div class="item_faq js-accordion__group">
        <div class="faq_heading js-accordion__menu">Why work with Luma instead of hiring an in-house designer?<span class="arrow_toggle"></span></div>
        <div class="descr_item_faq js-accordion__content"><div class="in_to_descr_fq">Bringing on a full-time designer is a hefty investment. Plus, finding that unicorn designer who can juggle the whole spectrum of design projects like a full-service team is tough. And let's not forget those moments when full-time designers are just twiddling their thumbs, yet you're still footing the bill.<br><br>This is where our flexible pricing model really shines! It's way more budget-friendly, and you get to work with a whole team of designers, each a pro in their own right.</div></div>
      </div>
      <div class="item_faq js-accordion__group">
        <div class="faq_heading js-accordion__menu">What are your typical turnaround times?<span class="arrow_toggle"></span></div>
        <div class="descr_item_faq js-accordion__content"><div class="in_to_descr_fq">Most of the time, your design requests get done super fast, usually in just two days or less. However, larger projects such as a multi-page ebook or a landing page take a bit longer. We've been known to build a small website in just two weeks!</div></div>
      </div>
      <div class="item_faq js-accordion__group">
        <div class="faq_heading js-accordion__menu">What happens if the results don't match my expectations?<span class="arrow_toggle"></span></div>
        <div class="descr_item_faq js-accordion__content"><div class="in_to_descr_fq">If our initial design drafts don't make you jump with joy, no sweat – we'll keep tweaking them until they do. Plus, we can loop in other talented designers from our team to spice things up with different styles. Your happiness is our priority!</div></div>
      </div>
      <div class="item_faq js-accordion__group">
        <div class="faq_heading js-accordion__menu">How do I make design requests and provide feedback?<span class="arrow_toggle"></span></div>
        <div class="descr_item_faq js-accordion__content"><div class="in_to_descr_fq">We run all our design magic through Asana. Just toss in all your design requests along with specs and guidelines. Once we have something to show you, share your thoughts directly in Asana or Figma comments.</div></div>
      </div>
      <div class="item_faq js-accordion__group">
        <div class="faq_heading js-accordion__menu">What type of deliverables should I expect?<span class="arrow_toggle"></span></div>
        <div class="descr_item_faq js-accordion__content"><div class="in_to_descr_fq">Figma is our main jam, but we're pretty chummy with Sketch and the whole Adobe suite too. Just let us know what you need, and we'll make sure to deliver your goodies in the format that suits you best.</div></div>
      </div>
      <div class="item_faq js-accordion__group">
        <div class="faq_heading js-accordion__menu">Who owns the designs that you produce?<span class="arrow_toggle"></span></div>
        <div class="descr_item_faq js-accordion__content"><div class="in_to_descr_fq">When it comes to copyright and ownership of the design work we produce for you, it's a straightforward deal – you own it all, 100%. No fine print.</div></div>
      </div>
      <div class="item_faq js-accordion__group">
        <div class="faq_heading js-accordion__menu">What types of companies typically work with you?<span class="arrow_toggle"></span></div>
        <div class="descr_item_faq js-accordion__content"><div class="in_to_descr_fq">Our bread and butter is working with tech startups and marketing agencies, but we've also had great collabs with industry titans and local service businesses.</div></div>
      </div>
      <div class="item_faq js-accordion__group">
        <div class="faq_heading js-accordion__menu">How do we get started?<span class="arrow_toggle"></span></div>
        <div class="descr_item_faq js-accordion__content"><div class="in_to_descr_fq">Getting the ball rolling is a breeze! All you gotta do is book an intro call with us! During our chat, we'll break down our process and have you up and running in Asana so you can start sending in design requests often within the same week!</div></div>
      </div>
    </div>
  </div>
</section>

</PageLayout>

<script define:vars={{ RECAPTCHA_SITE_KEY }}>
  // Pre-select plan from URL query param or hash (supports both ?plan=growth and #plan=growth)
  (() => {
    const params = new URLSearchParams(window.location.search);
    let plan = params.get('plan');
    if (!plan && window.location.hash.startsWith('#plan=')) {
      plan = window.location.hash.slice(6);
    }
    const select = document.getElementById('pricing_plan_select');
    if (plan && select) {
      const option = Array.from(select.options).find((o) => o.value === plan);
      if (option) select.value = plan;
    }
  })();

  // Wire "Get Started" buttons on plan cards: pre-select dropdown and smooth-scroll to form
  document.querySelectorAll('.plan_card__cta').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const planSlug = btn.getAttribute('data-plan');
      const select = document.getElementById('pricing_plan_select');
      if (planSlug && select) {
        select.value = planSlug;
      }
      const target = document.getElementById('contact');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Form handling
  const form = document.getElementById('pricing_form_el');
  const formContainer = document.getElementById('pricing_form_container');
  const thanksContainer = document.getElementById('pricing_form_thanks');

  if (form) {
    const nameEl = form.querySelector('.name');
    const companyEl = form.querySelector('.company');
    const phoneEl = form.querySelector('.phone');
    const websiteEl = form.querySelector('.website');
    const planEl = form.querySelector('.plan');

    const showError = (input, message) => {
      const field = input.parentElement;
      field.classList.remove('success');
      field.classList.add('error');
      const err = field.querySelector('.error_message');
      if (err) err.textContent = message;
    };

    const showSuccess = (input) => {
      const field = input.parentElement;
      field.classList.remove('error');
      field.classList.add('success');
      const err = field.querySelector('.error_message');
      if (err) err.textContent = '';
    };

    const checkName = () => {
      const v = nameEl.value.trim();
      if (!v || v.length < 2) { showError(nameEl, 'Name cannot be blank.'); return false; }
      showSuccess(nameEl); return true;
    };

    const checkCompany = () => {
      const v = companyEl.value.trim();
      if (!v) { showError(companyEl, 'Company name is required.'); return false; }
      showSuccess(companyEl); return true;
    };

    const checkPhone = () => {
      const v = phoneEl.value.trim();
      if (!v || v.length < 7) { showError(phoneEl, 'Please enter a valid phone number.'); return false; }
      showSuccess(phoneEl); return true;
    };

    const checkWebsite = () => {
      const v = websiteEl.value.trim();
      if (!v || v.length < 3) { showError(websiteEl, 'Website is required.'); return false; }
      showSuccess(websiteEl); return true;
    };

    const debounce = (fn, delay = 400) => {
      let id;
      return (...args) => { clearTimeout(id); id = setTimeout(() => fn(...args), delay); };
    };

    form.addEventListener('input', debounce((e) => {
      const t = e.target;
      if (t.classList.contains('name')) checkName();
      else if (t.classList.contains('company')) checkCompany();
      else if (t.classList.contains('phone')) checkPhone();
      else if (t.classList.contains('website')) checkWebsite();
    }));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!checkName() || !checkCompany() || !checkPhone() || !checkWebsite()) return;

      const submitBtn = form.querySelector('.submit_form_page');
      submitBtn?.classList.add('loading');

      try {
        const token = await new Promise((resolve) => {
          window.grecaptcha.ready(() => {
            window.grecaptcha.execute(RECAPTCHA_SITE_KEY, { action: 'pricing_page' }).then(resolve);
          });
        });

        const res = await fetch('/api/pricing-contact/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: nameEl.value.trim(),
            company: companyEl.value.trim(),
            phone: phoneEl.value.trim(),
            website: websiteEl.value.trim(),
            plan: planEl.value,
            recaptchaToken: token,
          }),
        });

        if (!res.ok) throw new Error('Server error');

        if (formContainer) formContainer.classList.add('hidden');
        if (thanksContainer) thanksContainer.classList.remove('hidden');
      } catch {
        submitBtn?.classList.remove('loading');
      }
    });
  }
</script>

<style>
  /* ── Breadcrumb ──────────────────────────────────────── */
  .breadcrumb_wrap { padding: 16px 0; border-top: 1px solid rgba(255,255,255,0.07); }
  .breadcrumb__list { display: flex; align-items: center; gap: 8px; list-style: none; margin: 0; padding: 0; font-size: 13px; color: rgba(255,255,255,0.4); }
  .breadcrumb__item::after { content: '/'; margin-left: 8px; color: rgba(255,255,255,0.25); }
  .breadcrumb__item:last-child::after { display: none; }
  .breadcrumb__link { color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.2s; }
  .breadcrumb__link:hover { color: #fff; }

  /* ── Hero ─────────────────────────────────────────────── */
  .pricing_hero_h1 {
    font-size: clamp(32px, 5vw, 56px);
    margin-bottom: 20px;
  }

  /* ── Pricing Plans ───────────────────────────────────── */
  .pricing_plans { padding: 96px 0; }

  .plan_grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .plan_card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 36px 28px 32px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    background: #212121;
  }

  .plan_card__name {
    position: absolute;
    top: -12px;
    left: 20px;
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    background: #3d3620;
    padding: 5px 12px;
    border-radius: 3px;
    z-index: 1;
  }

  .plan_card__hours {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 18px;
  }

  .plan_card__price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 20px;
  }

  .plan_card__amount {
    font-size: clamp(24px, 2.4vw, 30px);
    font-weight: 600;
    color: #fff;
    line-height: 1;
    font-family: 'Maison Neue', sans-serif;
  }

  .plan_card__period {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
