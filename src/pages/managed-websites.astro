---
import '../styles/instasite.css';
import PageLayout from '../layouts/PageLayout.astro';
import InstaSiteIsland from '../components/islands/InstaSiteIsland.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Luma Studios — Managed Websites for Local Businesses',
  description: 'Custom websites with no upfront costs. We build, host, and manage your site — plus marketing automations to capture more leads.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'Luma Studios',
    url: 'https://lumastudios.co',
  },
  serviceType: 'Web Design and Marketing Automation',
  areaServed: {
    '@type': 'Country',
    name: 'United States',
  },
  url: 'https://lumastudios.co/managed-websites',
};
---

<PageLayout
  title="Managed Websites for Local Businesses — Luma Studios"
  description="Custom websites with no upfront costs. We build, host, and manage your site — plus marketing automations to capture more leads."
  canonicalUrl="https://lumastudios.co/managed-websites"
  ogUrl="https://lumastudios.co/managed-websites"
  headerVariant="landing"
  bodyClass="landing_page"
  {jsonLd}
>

  <!-- ============================================================
       HERO — video background, transparent header overlay
       ============================================================ -->
  <section class="lp-hero">
    <video class="lp-hero__video" autoplay muted loop playsinline>
      <source src="/img/House_Painting_Video.mp4" type="video/mp4">
    </video>
    <div class="lp-hero__overlay"></div>

    <!-- Phone number — aligned with header bar, opposite the logo -->
    <div class="lp-hero__topbar">
      <a href="tel:+12073313928" class="lp-hero__phone">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M16.5 12.69v2.25a1.5 1.5 0 0 1-1.635 1.5 14.843 14.843 0 0 1-6.472-2.303 14.625 14.625 0 0 1-4.5-4.5A14.843 14.843 0 0 1 1.59 3.135 1.5 1.5 0 0 1 3.082 1.5H5.332a1.5 1.5 0 0 1 1.5 1.29 9.63 9.63 0 0 0 .525 2.108 1.5 1.5 0 0 1-.337 1.582L5.902 7.598a12 12 0 0 0 4.5 4.5l1.118-1.118a1.5 1.5 0 0 1 1.582-.338 9.63 9.63 0 0 0 2.108.525 1.5 1.5 0 0 1 1.29 1.523Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Call Us ‪(207) 331-3928‬
      </a>
    </div>

    <div class="lp-hero__content container">
      <h1 class="lp-hero__h1">Turn Your Website Into an Automated Sales Machine</h1>
      <p class="lp-hero__sub">We build websites for local businesses with <strong item-class-toggle>no upfront costs</strong> — now with marketing automations to ensure you never miss a sales opportunity.</p>
      <div class="lp-hero__ctas">
        <a href="#contact" class="btn_anim" data-scroll-to>
          <span class="default_btn_bg"></span>
          <span class="cb-btn_cta-title"><span data-text="Get in Touch">Get in Touch</span></span>
          <span class="cb-btn_cta-ripple"><span style="background-color: #212121;"></span></span>
        </a>
        <a href="#pricing" class="btn_anim outline" data-scroll-to>
          <span class="default_btn_bg"></span>
          <span class="cb-btn_cta-title"><span data-text="View Prices">View Prices</span></span>
          <span class="cb-btn_cta-ripple"><span style="background-color: #FFFC10;"></span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURES 4-UP — dark background
       ============================================================ -->
  <section class="lp-features">
    <div class="lp-features__deco" aria-hidden="true"></div>
    <img src="/img/cube_3d.webp" alt="" class="lp-features__cube" width="70" aria-hidden="true" loading="lazy">
    <div class="container">
      <div class="lp-features__grid">

        <div class="lp-feature-card">
          <div class="lp-feature-card__badge">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16.5007 32.2225V28.2783H5.94531C5.00837 28.2783 4.19073 27.9292 3.4924 27.2308C2.79434 26.5325 2.44531 25.715 2.44531 24.7783V7.77832C2.44531 6.84138 2.79434 6.02374 3.4924 5.3254C4.19073 4.62735 5.00837 4.27832 5.94531 4.27832H34.0561C34.9931 4.27832 35.8107 4.62735 36.5091 5.3254C37.2071 6.02374 37.5561 6.84138 37.5561 7.77832V24.7783C37.5561 25.715 37.2071 26.5325 36.5091 27.2308C35.8107 27.9292 34.9931 28.2783 34.0561 28.2783H23.5007V32.2225H25.3203C25.7975 32.2225 26.2061 32.3948 26.5461 32.7396C26.8861 33.0843 27.0561 33.4986 27.0561 33.9825C27.0561 34.4667 26.8861 34.8778 26.5461 35.2158C26.2061 35.5536 25.7975 35.7225 25.3203 35.7225H14.7091C14.2138 35.7225 13.796 35.5503 13.4557 35.2058C13.1155 34.8611 12.9453 34.4467 12.9453 33.9625C12.9453 33.4786 13.1155 33.0676 13.4557 32.7296C13.796 32.3915 14.2138 32.2225 14.7091 32.2225H16.5007ZM5.94531 24.7783H34.0561V7.77832H5.94531V24.7783Z" fill="#7056E3"/><path d="M16 12C17.6569 12 19 13.3431 19 15V18C19 19.6051 17.7394 20.9158 16.1543 20.9961L16 21H13L12.8457 20.9961C11.3117 20.9184 10.0816 19.6883 10.0039 18.1543L10 18V15C10 13.3431 11.3431 12 13 12H16ZM28.5 18C29.3284 18 30 18.6716 30 19.5C30 20.3284 29.3284 21 28.5 21H23.5C22.6716 21 22 20.3284 22 19.5C22 18.6716 22.6716 18 23.5 18H28.5ZM13 18H16V15H13V18ZM28.5 13C29.3284 13 30 13.6716 30 14.5C30 15.3284 29.3284 16 28.5 16H23.5C22.6716 16 22 15.3284 22 14.5C22 13.6716 22.6716 13 23.5 13H28.5Z" fill="#CAB2FF"/></svg>
          </div>
          <div class="lp-feature-card__content">
            <h2 class="lp-feature-card__title">Custom Web Design</h2>
            <p class="lp-feature-card__body">We don't use generic templates. You get a high converting, custom-designed site tailored to your brand, built specifically to turn casual browsers into booked appointments.</p>
          </div>
        </div>

        <div class="lp-feature-card">
          <div class="lp-feature-card__badge">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20.3018 6.11914C20.7864 6.39865 21.4646 6.77987 22.2422 7.18457C23.7624 7.9758 25.7885 8.9275 27.4961 9.33887C29.1624 9.74024 31.2421 9.78019 32.7998 9.74023C33.4356 9.72394 33.8964 10.2219 33.8965 10.7227V15.0957C33.8964 23.834 28.4553 31.6261 20.2979 34.6562C12.1405 31.6261 6.69927 23.834 6.69922 15.0957V10.7227L6.7041 10.6289C6.75709 10.1617 7.19991 9.72501 7.7959 9.74023C9.35354 9.78019 11.4334 9.74022 13.0996 9.33887C14.8072 8.9275 16.8333 7.97579 18.3535 7.18457C19.1311 6.77987 19.8093 6.39865 20.2939 6.11914C20.2953 6.11838 20.2965 6.11697 20.2979 6.11621C20.2992 6.11699 20.3004 6.11836 20.3018 6.11914Z" stroke="#CAB2FF" stroke-width="3"/><path d="M20.2949 13.5293C20.5321 13.6801 20.8072 13.8515 21.1074 14.0273C22.0144 14.5585 23.3157 15.2444 24.4707 15.4961C25.5614 15.7337 26.8498 15.6392 27.7852 15.5176V16.6855C27.7851 21.4707 24.7703 25.7162 20.2949 27.3125C15.8197 25.7161 12.8048 21.4706 12.8047 16.6855V15.5176C13.74 15.6393 15.0283 15.7337 16.1191 15.4961C17.2741 15.2445 18.5754 14.5585 19.4824 14.0273C19.7826 13.8516 20.0578 13.6801 20.2949 13.5293Z" stroke="#773CF7" stroke-width="3"/></svg>
          </div>
          <div class="lp-feature-card__content">
            <h2 class="lp-feature-card__title">Zero-Stress Management</h2>
            <p class="lp-feature-card__body">From lightning-fast hosting to security updates and unlimited content edits, we manage everything for you. You'll never have to touch clunky web design software again.</p>
          </div>
        </div>

        <div class="lp-feature-card">
          <div class="lp-feature-card__badge">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17.4174 21.2363L19.7786 23.5972C20.0298 23.8472 20.3495 23.9722 20.7378 23.9722C21.1261 23.9722 21.4545 23.8472 21.7228 23.5972L26.9453 18.3751V20.0417C26.9453 20.4215 27.0784 20.7409 27.3445 21.0001C27.6106 21.2592 27.9405 21.3888 28.3341 21.3888C28.7138 21.3888 29.0402 21.2558 29.3132 20.9897C29.5863 20.7236 29.7228 20.3937 29.7228 20.0001V15.0001C29.7228 14.6204 29.5863 14.294 29.3132 14.0209C29.0402 13.7479 28.7138 13.6113 28.3341 13.6113H23.2924C22.9127 13.6113 22.5932 13.7479 22.3341 14.0209C22.0749 14.294 21.9453 14.6249 21.9453 15.0138C21.9453 15.4027 22.0784 15.7291 22.3445 15.993C22.6106 16.2569 22.9405 16.3888 23.3341 16.3888H24.9591L20.7507 20.6388L18.3895 18.278C18.1211 18.0002 17.7928 17.8613 17.4045 17.8613C17.0161 17.8613 16.6964 18.0002 16.4453 18.278L11.362 23.3613C11.0842 23.6297 10.9453 23.9586 10.9453 24.348C10.9453 24.7374 11.0878 25.0581 11.3728 25.3101C11.6339 25.5848 11.9586 25.7222 12.347 25.7222C12.7353 25.7222 13.055 25.5833 13.3061 25.3055L17.4174 21.2363Z" fill="#CAB2FF"/><path d="M7.77734 35.7225C6.8404 35.7225 6.02276 35.3735 5.32443 34.6754C4.62637 33.9771 4.27734 33.1594 4.27734 32.2225V7.77832C4.27734 6.84138 4.62637 6.02374 5.32443 5.3254C6.02276 4.62735 6.8404 4.27832 7.77734 4.27832H32.2215C33.1585 4.27832 33.9761 4.62735 34.6744 5.3254C35.3725 6.02374 35.7215 6.84138 35.7215 7.77832V32.2225C35.7215 33.1594 35.3725 33.9771 34.6744 34.6754C33.9761 35.3735 33.1585 35.7225 32.2215 35.7225H7.77734ZM7.77734 32.2225H32.2215V7.77832H7.77734V32.2225Z" fill="#7056E3"/></svg>
          </div>
          <div class="lp-feature-card__content">
            <h2 class="lp-feature-card__title">Growth-Ready Strategy</h2>
            <p class="lp-feature-card__body">We build marketing automations and offer training to help you scale. We don't just hand you a login; we sit down with you to ensure your digital presence is actually moving your bottom line.</p>
          </div>
        </div>

        <div class="lp-feature-card">
          <div class="lp-feature-card__badge">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M33.7208 19.9171C33.2805 19.9171 32.8949 19.7619 32.5641 19.4516C32.2336 19.1416 32.0312 18.7412 31.957 18.2504C31.5681 15.5559 30.4015 13.2365 28.457 11.2921C26.5126 9.34761 24.1931 8.18094 21.4987 7.79205C21.0079 7.71789 20.6074 7.50469 20.2974 7.15247C19.9872 6.80025 19.832 6.39775 19.832 5.94497C19.832 5.42414 20.007 5.00914 20.357 4.69997C20.707 4.39108 21.1154 4.25511 21.582 4.29205C25.2295 4.73233 28.3422 6.24427 30.9199 8.82789C33.4977 11.4115 35.0101 14.5246 35.457 18.1671C35.494 18.6337 35.3429 19.0421 35.0037 19.3921C34.6643 19.7421 34.2366 19.9171 33.7208 19.9171ZM26.5062 19.9171C26.1309 19.9171 25.7913 19.7887 25.4874 19.5321C25.1838 19.2754 24.9608 18.9176 24.8183 18.4587C24.5588 17.6346 24.119 16.9077 23.4987 16.2783C22.8784 15.6486 22.1423 15.2041 21.2904 14.945C20.8468 14.8061 20.4929 14.5829 20.2287 14.2754C19.9643 13.9682 19.832 13.6294 19.832 13.2591C19.832 12.6766 20.0311 12.2077 20.4291 11.8525C20.8274 11.4975 21.2812 11.3708 21.7904 11.4725C23.4001 11.8605 24.7933 12.6404 25.9699 13.8121C27.1466 14.984 27.9294 16.3662 28.3183 17.9587C28.4386 18.4679 28.3109 18.9216 27.9354 19.32C27.5598 19.718 27.0834 19.9171 26.5062 19.9171Z" fill="#CAB2FF"/><path d="M34.0481 35.8888C30.4592 35.8888 26.8731 35.0833 23.2898 33.4722C19.7065 31.8611 16.4194 29.5672 13.4285 26.5905C10.438 23.6136 8.13715 20.3265 6.52604 16.7292C4.91493 13.132 4.10938 9.53897 4.10938 5.95008C4.10938 5.38563 4.27465 4.938 4.60521 4.60716C4.93604 4.27661 5.38188 4.11133 5.94271 4.11133H13.1369C13.5366 4.11133 13.8842 4.24786 14.1798 4.52091C14.4753 4.79397 14.6741 5.12966 14.776 5.52799L15.996 11.7955C16.0344 12.1727 16.0166 12.522 15.9427 12.8434C15.8685 13.1651 15.746 13.4138 15.5752 13.5897L11.2202 18.028C11.8408 19.1205 12.5399 20.1644 13.3177 21.1597C14.0955 22.1552 14.9612 23.1205 15.9148 24.0555C16.8592 25.0277 17.8408 25.9074 18.8594 26.6947C19.8777 27.4816 20.924 28.1761 21.9981 28.778L26.3869 24.4167C26.6277 24.1576 26.898 23.9816 27.1977 23.8888C27.4974 23.7963 27.792 23.7779 28.0815 23.8334L34.4148 25.2222C34.814 25.3333 35.1591 25.549 35.4502 25.8692C35.7413 26.1895 35.8869 26.548 35.8869 26.9447V34.0555C35.8869 34.6163 35.7216 35.0622 35.391 35.393C35.0602 35.7236 34.6126 35.8888 34.0481 35.8888ZM9.52604 14.778L12.4702 11.8055L11.6102 7.61133H7.72021C7.80354 8.80577 7.98188 9.96313 8.25521 11.0834C8.52826 12.2037 8.95188 13.4352 9.52604 14.778ZM25.3035 30.5001C26.3685 30.9815 27.5052 31.3773 28.7135 31.6876C29.9219 31.9979 31.1463 32.2038 32.3869 32.3055V32.3334V28.3334L28.2202 27.4447L25.3035 30.5001Z" fill="#7056E3"/></svg>
          </div>
          <div class="lp-feature-card__content">
            <h2 class="lp-feature-card__title">Automated Lead Capture</h2>
            <p class="lp-feature-card__body">Our websites come with marketing automation. We integrate smart capture forms that don't just sit there — they instantly notify you and organize your prospects for easy follow-ups.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       SOCIAL PROOF — testimonial + video thumbnail
       ============================================================ -->
  <section class="lp-social">
    <div class="container">
      <h2 class="lp-social__heading">What Our Clients Say</h2>
      <div class="lp-social__inner">

        <!-- LEFT: photo + video CTA -->
        <div class="lp-social__left">
          <div class="lp-social__media">
            <img src="/img/midnight-alex.webp" alt="Alex Nelson, Owner of Midnight Coffee" loading="lazy">
          </div>
          <button class="lp-social__video-link" data-video-open>
            <span class="lp-social__video-play" aria-hidden="true">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6 4l16 8-16 8V4z"/></svg>
            </span>
            Watch Alex's Video Review
          </button>
        </div>

        <!-- RIGHT: quote card -->
        <div class="lp-social__card">
          <svg class="lp-social__quote-mark" width="40" height="28" viewBox="0 0 40 28" fill="none" aria-hidden="true">
            <path d="M0 28V17.111C0 7.481 5.926 1.963 17.778 0l2.37 3.852C14.42 5.037 11.26 8.074 10.667 13.333H18V28H0ZM22 28V17.111C22 7.481 27.926 1.963 39.778 0l2.37 3.852C36.42 5.037 33.26 8.074 32.667 13.333H40V28H22Z" fill="#333"/>
          </svg>
          <blockquote class="lp-testimonial__quote">
            The team at Luma Studios was organized, creative, and easy to work with. They nailed our brand vision with a clean, modern site that truly feels like Midnight Coffee. Communication was fast, timelines were clear, and every edit was handled with care. We're proud to send customers to our site now — highly recommend.
          </blockquote>
          <hr class="lp-social__divider">
          <div class="lp-testimonial__author">
            <img src="/img/alex-small.webp" alt="Alex Nelson" class="lp-testimonial__avatar" width="48" height="48" loading="lazy">
            <div>
              <p class="lp-testimonial__name">Alex Nelson</p>
              <p class="lp-testimonial__role">Owner — Midnight Coffee</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       MARKETING AUTOPILOT — checklist + image
       ============================================================ -->
  <section class="lp-autopilot">
    <div class="container">
      <div class="lp-autopilot__grid">
        <div>
          <span class="lp-autopilot__badge">Marketing Automations</span>
          <h2 class="lp-autopilot__h2">Marketing on Auto-Pilot</h2>
          <p class="lp-autopilot__support">We've partnered with industry-leading software providers to build a marketing "brain" for your business. We don't just give you a tool — we build the system and teach you how to use it.</p>
          <ul class="lp-check-list">
            <li class="lp-check-list__item">
              <span class="lp-check-list__dot">
                <svg viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="#161616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <div>
                <p class="lp-check-list__title">Custom Pipeline Setup</p>
                <p class="lp-check-list__body">We map out your customers' journey from the first click to the signed contract to help you gain better insights into your lead pipeline.</p>
              </div>
            </li>
            <li class="lp-check-list__item">
              <span class="lp-check-list__dot">
                <svg viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="#161616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <div>
                <p class="lp-check-list__title">Automated Nurture Sequences</p>
                <p class="lp-check-list__body">Personalized email and text follow-ups that go out automatically, keeping you top-of-mind without you lifting a finger.</p>
              </div>
            </li>
            <li class="lp-check-list__item">
              <span class="lp-check-list__dot">
                <svg viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="#161616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <div>
                <p class="lp-check-list__title">1-on-1 Systems Training</p>
                <p class="lp-check-list__body">We spend time with you and your team to ensure you're a pro at using your new dashboard to track, manage, and close every lead.</p>
              </div>
            </li>
          </ul>
        </div>
        <div class="lp-autopilot__img">
          <img src="/img/instasite/marketing.webp" alt="Marketing automation dashboard for local businesses" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       BENEFITS 6-UP
       ============================================================ -->
  <section class="lp-benefits">
    <div class="container">
      <div class="lp-benefits__intro">
        <h2 class="lp-title" style="margin-bottom: 0;">Tools to Grow Your Business</h2>
      </div>
      <div class="lp-benefits__grid">
        <div class="lp-benefit-card">
          <div class="lp-benefit-card__icon"><img src="/img/instasite/Ultimate%20Performance%20Optimization.svg" alt="" loading="lazy"></div>
          <h3 class="lp-benefit-card__title">Performance Optimization</h3>
          <p class="lp-benefit-card__body">We build with a "Google-First" mindset and mobile-first engineering. By ensuring your business is ultra-fast and easy to find on every screen, we make sure local customers connect with you the second they need your services.</p>
        </div>
        <div class="lp-benefit-card">
          <div class="lp-benefit-card__icon"><img src="/img/instasite/Instant%20Response%20Automation.svg" alt="" loading="lazy"></div>
          <h3 class="lp-benefit-card__title">Instant Response Automation</h3>
          <p class="lp-benefit-card__body">The first business to respond usually wins the job. Our marketing automation tools send instant SMS and email replies to new leads, keeping them engaged while you're busy doing your work.</p>
        </div>
        <div class="lp-benefit-card">
          <div class="lp-benefit-card__icon"><img src="/img/instasite/Centralized%20Lead%20Dashboard.svg" alt="" loading="lazy"></div>
          <h3 class="lp-benefit-card__title">Centralized Lead Dashboard</h3>
          <p class="lp-benefit-card__body">Stop digging through your inbox. We set up a simple CRM tool that collects all leads in one place, showing you exactly who to call next.</p>
        </div>
        <div class="lp-benefit-card">
          <div class="lp-benefit-card__icon"><img src="/img/instasite/Unlimited%20updates.svg" alt="" loading="lazy"></div>
          <h3 class="lp-benefit-card__title">Unlimited Updates</h3>
          <p class="lp-benefit-card__body">Your business is always evolving, and your site should too. We handle all content changes and updates at no extra cost, so your site never goes stale.</p>
        </div>
        <div class="lp-benefit-card">
          <div class="lp-benefit-card__icon"><img src="/img/instasite/Low%20monthly%20payments.svg" alt="" loading="lazy"></div>
          <h3 class="lp-benefit-card__title">Low Monthly Payments</h3>
          <p class="lp-benefit-card__body">Get a secure enterprise-grade website and marketing suite for one predictable monthly fee. No huge down payments — just a low cost to keep your business growing.</p>
        </div>
        <div class="lp-benefit-card">
          <div class="lp-benefit-card__icon"><img src="/img/instasite/reliable%20human%20support.svg" alt="" loading="lazy"></div>
          <h3 class="lp-benefit-card__title">Reliable Human Support</h3>
          <p class="lp-benefit-card__body">Forget chatbots and support tickets. If you have an issue or just need a question answered, you can call us directly. We're your local partners, here to sort things out so you can focus on your work.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       RECENT PROJECTS — alternating image/text
       ============================================================ -->
  <section class="lp-projects">
    <div class="container">
      <div class="lp-projects__intro">
        <div class="lp-projects__title-row">
          <span class="line_centr_lef"></span>
