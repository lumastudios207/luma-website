---
import PageLayout from '../layouts/PageLayout.astro';
import QuoteBlock from '../components/ui/QuoteBlock.astro';
import GetStartCTA from '../components/ui/GetStartCTA.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CreativeWork",
      "name": "Secureframe Case Study — Luma Studios",
      "description": "How Luma Studios helped Secureframe grow from early-stage startup to industry leader with brand identity, website design, billboards, and sales collateral.",
      "url": "https://lumastudios.co/secureframe/",
      "author": { "@type": "Organization", "name": "Luma Studios" },
      "about": { "@type": "Organization", "name": "Secureframe" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lumastudios.co/" },
        { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://lumastudios.co/projects/" },
        { "@type": "ListItem", "position": 3, "name": "Secureframe", "item": "https://lumastudios.co/secureframe/" }
      ]
    }
  ]
};
---

<PageLayout
  title="Secureframe Brand & Web Design Case Study | Luma Studios"
  description="How Luma Studios helped Secureframe build a complete brand system, website, billboard campaign, and sales collateral from early-stage startup to industry leader."
  canonicalUrl="https://lumastudios.co/secureframe/"
  ogUrl="https://lumastudios.co/secureframe/"
  ogImage="https://lumastudios.co/img/og/og_image.jpg"
  jsonLd={jsonLd}
  headerVariant="case-study"
  hasVerticalSlider={true}
>
  <div class="overflow-hidden">
    <div class="default_first_pt info_first_scr first_load_section">
      <div class="block_project_g" first-load-delay>
        <div class="container">
          <div class="wrap_text_proj">
            <div class="texts_lgs_go">
              <div class="subitt_sgsg" data-anim-project>Client Case Study</div>
              <h1 class="title_proj_g" data-anim-project>Secureframe</h1>
              <div class="descr_proj_gg" data-anim-project>Secureframe helps companies build trust and stay secure with compliance automation software.</div>
              <div class="titl_contrib_gg" data-anim-project>Our Contribution</div>
              <div class="list_designed" data-anim-project>
                <div class="wrp_contr_g">
                  <div class="item_contrib_b">Brand Identity</div>
                  <div class="item_contrib_b">Website</div>
                  <div class="item_contrib_b">Investor Decks</div>
                  <div class="item_contrib_b">Billboards</div>
                  <div class="item_contrib_b">Conference Banners</div>
                </div>
              </div>
              <div class="decor_proj_gg">
                <div class="square_dec_go">
                  <img src="/img/triangle.webp" alt="" width="90" loading="lazy">
                </div>
                <div class="cube_de_lef">
                  <img src="/img/cube_3d.webp" alt="" width="108" loading="lazy">
                </div>
              </div>
            </div>
            <div class="preview_secur_frm">
              <img src="/img/secureframe_preview.webp" width="734" alt="Secureframe brand and web design project by Luma Studios" loading="lazy">
            </div>
            <div class="icons_info_sg">
              <img src="/img/d_icons_project.svg" alt="" loading="lazy">
            </div>
          </div>
        </div>
      </div>
    </div>

    <QuoteBlock
      quote="The guys at Luma Studios helped us on a number of fronts. They designed our marketing site, created effective pitch decks that helped us raise millions from investors, designed our conference signage and billboards. We were super impressed with the quality of their work, turn-around time, and responsiveness throughout the process."
      name="Shrav Mehta"
      title="Founder and CEO"
      company="Secureframe"
      personImg="/img/image_quote.webp"
      logoSrc="/img/secureframe.svg"
    />

    <section class="logo_design section_pt">
      <div class="container">
        <div class="headint_sec">
          <h2 class="title_section text-center">Brand Identity Design</h2>
          <div class="wrap_descr_subi">
            <div class="descr_subitle_g">Secureframe needed a solid brand identity to attract their first customers after launching V1 of their web app. We worked together through multiple iterations to design the logo, color palette, and typography suite. The result was a simple-yet-memorable brand book that supported their growth from an early-stage startup to a well-funded industry leader.</div>
            <div class="smaller_we quote_decor_top">
              <div class="line_gksg">
                <svg width="2542" height="93" viewBox="0 0 2542 93" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.5 92L135 1H2542" stroke="#464646"/>
                </svg>
                <div class="quote_cub_bb">
                  <img src="/img/cube_3d.webp" alt="" width="67" loading="lazy">
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="logo_proj_g text-center">
          <img class="img-responsive mx-auto" src="/img/logo-secureframe.svg" width="688" alt="Secureframe logo" loading="lazy">
        </div>
        <div class="block_palette grid grid-cols-4">
          <div class="item_pallet_g">
            <div class="color_pallete flex items-end" style="background-color: #73E5D2;color: #1F2E33;">
              <span class="text_color_pall transition">Mint Green</span>
            </div>
            <div class="descr_pallete">
              <div class="tx_pal_item flex items-center"><div>HEX</div><div>#73E6D2</div></div>
              <div class="tx_pal_item flex items-center"><div>RGB</div><div>115, 230, 210</div></div>
              <div class="tx_pal_item flex items-center"><div>CMYK</div><div>50, 0, 9, 10</div></div>
            </div>
          </div>
          <div class="item_pallet_g">
            <div class="color_pallete flex items-end" style="background-color: #177EE5;">
              <span class="text_color_pall transition">Royal Blue</span>
            </div>
            <div class="descr_pallete">
              <div class="tx_pal_item flex items-center"><div>HEX</div><div>#177EE5</div></div>
              <div class="tx_pal_item flex items-center"><div>RGB</div><div>23, 126, 229</div></div>
              <div class="tx_pal_item flex items-center"><div>CMYK</div><div>90, 45, 0, 10</div></div>
            </div>
          </div>
          <div class="item_pallet_g">
            <div class="color_pallete flex items-end" style="background-color: #5656BF;">
              <span class="text_color_pall transition">Deep Purple</span>
            </div>
            <div class="descr_pallete">
              <div class="tx_pal_item flex items-center"><div>HEX</div><div>#5656BF</div></div>
              <div class="tx_pal_item flex items-center"><div>RGB</div><div>86, 86, 191</div></div>
              <div class="tx_pal_item flex items-center"><div>CMYK</div><div>90, 40, 0, 10</div></div>
            </div>
          </div>
          <div class="item_pallet_g">
            <div class="color_pallete flex items-end" style="background-color: #1E294D;">
              <span class="text_color_pall transition">Heavy Blue</span>
            </div>
            <div class="descr_pallete">
              <div class="tx_pal_item flex items-center"><div>HEX</div><div>#1E294D</div></div>
              <div class="tx_pal_item flex items-center"><div>RGB</div><div>30, 41, 77</div></div>
              <div class="tx_pal_item flex items-center"><div>CMYK</div><div>18, 14, 0, 70</div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="info_des_goo section_py">
      <div class="container">
        <div class="headint_sec">
          <h2 class="title_section text-center">Billboard Design</h2>
          <div class="wrap_descr_subi">
            <div class="descr_subitle_g">To reach new enterprise customers, we worked with Secureframe to design a series of ads that appeared along Highway 101 in San Francisco and throughout the NYC subway. By pairing simple graphic elements with concise copy, we helped the brand communicate what it does in a fun, memorable way.</div>
          </div>
        </div>
        <div class="billboard_gallery mb-0">
          <div class="img_billboard">
            <img class="img-responsive mx-auto w-full" src="/img/bilboard_img_1.webp" alt="Secureframe billboard advertisement design" loading="lazy">
          </div>
          <div class="wrap_bild_two grid grid-cols-2">
            <div class="img_billboard">
              <img class="img-responsive mx-auto w-full" src="/img/bilboard_img_2.webp" alt="Secureframe billboard advertisement design" loading="lazy">
            </div>
            <div class="img_billboard">
              <img class="img-responsive mx-auto w-full" src="/img/bilboard_img_3.webp" alt="Secureframe billboard advertisement design" loading="lazy">
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="sec_website pt-0 section_pb">
      <div class="container">
        <div class="headint_sec">
          <h2 class="title_section text-center">Website Design</h2>
          <div class="wrap_descr_subi">
            <div class="descr_subitle_g">As Secureframe has transitioned from targeting smaller companies to enterprise-level customers, the website has evolved too. We've worked with the marketing team to incorporate more informative content, new graphics, and a subtler, darker color palette.</div>
            <div class="smaller_we quote_decor_top">
              <div class="line_gksg">
                <svg width="2542" height="93" viewBox="0 0 2542 93" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.5 92L135 1H2542" stroke="#464646"/>
                </svg>
                <div class="quote_cub_bb">
                  <img src="/img/cube_3d.webp" alt="" width="67" loading="lazy">
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="websites_photos dark_bg">
      <div class="container">
        <div class="first_preview_img">
          <div class="wrap_preview_img">
            <img class="img-responsive w-full" src="/img/website/secureframe/preview.webp" loading="lazy" alt="Secureframe marketing website design">
          </div>
          <div class="line_bott_gg"></div>
        </div>
        <div class="website_examples grid grid-cols-2">
          <div class="item_row_webs">
            <div class="item_website_img">
              <img class="img-responsive w-full" src="/img/website/secureframe/website_img_1.webp" loading="lazy" alt="Secureframe website design">
            </div>
          </div>
          <div class="item_row_webs">
            <div class="item_website_img">
              <img class="img-responsive w-full" src="/img/website/secureframe/website_img_2.webp" loading="lazy" alt="Secureframe website design">
            </div>
          </div>
          <div class="item_row_webs one-row">
            <div class="item_website_img">
              <img class="img-responsive w-full" src="/img/website/secureframe/website_img_3.webp" loading="lazy" alt="Secureframe website design">
            </div>
          </div>
          <div class="item_row_webs">
            <div class="item_website_img">
              <img class="img-responsive w-full" src="/img/website/secureframe/website_img_4.webp" loading="lazy" alt="Secureframe website design">
            </div>
          </div>
          <div class="item_row_webs">
            <div class="item_website_img">
              <img class="img-responsive w-full" src="/img/website/secureframe/website_img_5.webp" loading="lazy" alt="Secureframe website design">
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="sec_icons_frame section_py">
      <div class="container">
        <div class="headint_sec">
          <h2 class="title_section text-center">Custom Icons</h2>
        </div>
        <div class="wrap_icons grid">
          <div class="item_icon_go">
            <div class="wrap_img_icon"><img src="/img/icons/frame_icon_1.svg" width="135" height="135" alt="" loading="lazy"></div>
            <div class="name_icon_text">SOC 2</div>
          </div>
          <div class="item_icon_go">
            <div class="wrap_img_icon"><img src="/img/icons/frame_icon_2.svg" width="135" height="135" alt="" loading="lazy"></div>
            <div class="name_icon_text">GDPR</div>
          </div>
          <div class="item_icon_go">
            <div class="wrap_img_icon"><img src="/img/icons/frame_icon_3.svg" width="135" height="135" alt="" loading="lazy"></div>
            <div class="name_icon_text">CCPA</div>
          </div>
          <div class="item_icon_go">
            <div class="wrap_img_icon"><img src="/img/icons/frame_icon_4.svg" width="135" height="135" alt="" loading="lazy"></div>
            <div class="name_icon_text">ISO 27001</div>
          </div>
          <div class="item_icon_go">
            <div class="wrap_img_icon"><img src="/img/icons/frame_icon_5.svg" width="135" height="135" alt="" loading="lazy"></div>
            <div class="name_icon_text">HIPAA</div>
          </div>
          <div class="item_icon_go">
            <div class="wrap_img_icon"><img src="/img/icons/frame_icon_6.svg" width="135" height="135" alt="" loading="lazy"></div>
            <div class="name_icon_text">PCI DSS</div>
          </div>
        </div>
      </div>
    </section>

    <section class="ilustratons_d dark_bg section_py">
      <div class="container">
        <div class="headint_sec">
          <h2 class="title_section text-center">3D Frameworks Illustrations</h2>
        </div>
        <div class="wrap_ilustration_gg">
          <img class="img-responsive mx-auto" src="/img/illustration.webp" width="1143" alt="Secureframe 3D frameworks illustration" loading="lazy">
        </div>
      </div>
    </section>

    <section class="info_des_goo section_py">
      <div class="container">
        <div class="headint_sec">
          <h2 class="title_section text-center">Sales Collateral</h2>
          <div class="wrap_descr_subi">
            <div class="descr_subitle_g">We collaborated with Secureframe to produce a variety of marketing materials, including one-page PDFs for the sales team, information booklets for the recruiting team, and leave-behinds and banners for the conferences that Secureframe attended.</div>
          </div>
        </div>
        <div class="sec_wrp_gio wrap_bild_two grid grid-cols-2">
          <div class="img_billboard"><img class="img-responsive mx-auto w-full" src="/img/sales_collater_1.webp" alt="Secureframe sales collateral design" loading="lazy"></div>
          <div class="img_billboard"><img class="img-responsive mx-auto w-full" src="/img/sales_collater_2.webp" alt="Secureframe sales collateral design" loading="lazy"></div>
          <div class="img_billboard"><img class="img-responsive mx-auto w-full" src="/img/sales_collater_3.webp" alt="Secureframe sales collateral design" loading="lazy"></div>
          <div class="img_billboard"><img class="img-responsive mx-auto w-full" src="/img/sales_collater_4.webp" alt="Secureframe sales collateral design" loading="lazy"></div>
        </div>
      </div>
    </section>

    <GetStartCTA />
  </div>
</PageLayout>
