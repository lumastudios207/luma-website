---
import PageLayout from '../layouts/PageLayout.astro';
import { site } from '../data/site';
import { icons } from '../components/icons/icons';

const RECAPTCHA_SITE_KEY = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY ?? '6Led6ogsAAAAAFaFaM50DpZNy4glFZvN8fH-5yEX';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ContactPage',
      name: 'Contact Luma Studios',
      url: 'https://lumastudios.co/contact/',
      description:
        'Get in touch with Luma Studios to discuss your web design, development, or SEO project. Based in Portland, Maine — serving clients across the U.S.',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lumastudios.co/' },
        { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://lumastudios.co/contact/' },
      ],
    },
    {
      '@type': 'LocalBusiness',
      name: 'Luma Studios',
      url: 'https://lumastudios.co',
      telephone: site.phonePlain,
      email: site.email,
      address: {
        '@type': 'PostalAddress',
        streetAddress: '63 Federal Street',
        addressLocality: 'Portland',
        addressRegion: 'ME',
        postalCode: '04101',
        addressCountry: 'US',
      },
      openingHoursSpecification: [
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
          opens: '09:00',
          closes: '18:00',
        },
      ],
    },
  ],
};
---

<PageLayout
  title="Contact Luma Studios | Get a Free Project Quote"
  description="Ready to start a web design, development, or SEO project? Reach out to Luma Studios in Portland, Maine. We reply the same business day."
  canonicalUrl="https://lumastudios.co/contact/"
  ogUrl="https://lumastudios.co/contact/"
  {jsonLd}
>

<!-- ===================== BREADCRUMB ===================== -->
<div class="breadcrumb_wrap">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="/" class="breadcrumb__link">Home</a></li>
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">Contact</li>
      </ol>
    </nav>
  </div>
</div>

<!-- ===================== CONTACT HERO ===================== -->
<section class="contact_hero" first-load-delay>
  <div class="container">
    <div class="contact_hero__inner grid grid-cols-2">
      <div class="contact_hero__left">
        <h1 class="heading_home contact_h1">Send us a message or <span class="blue_color">book a free discovery session.</span></h1>
        <p class="contact_intro">
          We'll take a look at your current online presence and show you exactly how to take it to the next level. If nothing else, you'll walk away with a clear roadmap to a stronger website and smarter marketing.
        </p>
        <ul class="contact_trust_list">
          <li class="contact_trust_item">
            <span class="contact_trust_check">
              <svg viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#8B5CF6"/><path d="M5.5 10l3 3 6-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            100% Free Consultation
          </li>
          <li class="contact_trust_item">
            <span class="contact_trust_check">
              <svg viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#8B5CF6"/><path d="M5.5 10l3 3 6-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Actionable Growth Advice
          </li>
          <li class="contact_trust_item">
            <span class="contact_trust_check">
              <svg viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#8B5CF6"/><path d="M5.5 10l3 3 6-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Same-Day Response
          </li>
        </ul>
        <div class="contact_direct">
          <div class="contact_direct_row">
            <span class="contact_direct_icon"><Fragment set:html={icons.phone} /></span>
            <a href={`tel:${site.phonePlain}`} class="contact_direct_link">{site.phone}</a>
          </div>
          <div class="contact_direct_row">
            <span class="contact_direct_icon"><Fragment set:html={icons.calendar} /></span>
            <a href={site.social.calendly} class="contact_direct_link" target="_blank" rel="noopener noreferrer">Book a 30-Minute Call</a>
          </div>
        </div>
      </div>

      <!-- =============== FORM =============== -->
      <div class="contact_form_wrap">
        <img src="/img/cube_3d.webp" alt="" class="contact_form_cube" width="80" loading="lazy" aria-hidden="true">
        <div id="contact_page_form">
          <form id="contact_page_form_el" novalidate>
            <div class="row_form_inp grid grid-cols-2">
              <div class="form_group">
                <input type="text" placeholder="Your Name" name="name" class="name form_control" autocomplete="given-name">
                <small class="error_message"></small>
                <span class="underline_inp"></span>
              </div>
              <div class="form_group">
                <input type="email" placeholder="Your E-mail" name="email" class="email form_control" autocomplete="email">
                <small class="error_message"></small>
                <span class="underline_inp"></span>
              </div>
            </div>
            <div class="row_form_inp">
              <div class="form_group">
                <input type="text" placeholder="Business Name" name="company" class="company form_control" autocomplete="organization">
                <small class="error_message"></small>
                <span class="underline_inp"></span>
              </div>
            </div>
            <div class="row_form_inp">
              <div class="form_group">
                <textarea placeholder="Tell us about your project — what you need, your timeline, and any other details that help us prepare." name="message" class="message form_control" rows="5"></textarea>
                <small class="error_message"></small>
                <span class="underline_inp"></span>
              </div>
            </div>
            <div class="footer_form">
              <div class="flex items-center justify-end">
                <button type="submit" class="btn_anim submit_form_page">
                  <span class="default_btn_bg"></span>
                  <span class="cb-btn_cta-title">
                    <span data-text="Send Message">Send Message</span>
                  </span>
                  <span class="cb-btn_cta-ripple">
                    <span style="background-color: #212121;"></span>
                  </span>
                </button>
              </div>
            </div>
          </form>
        </div>
        <div class="contact_thanks hidden" id="contact_page_thanks">
          <div class="thansk_wrapp_go">
            <div class="decor_top_sg">
              <img src="/img/triangle.webp" alt="" width="70" loading="lazy">
            </div>
            <div class="subtitle_formgg">Thank you!</div>
            <div class="item_tzg">Your message has been received. We'll review your details and get back to you within one business day.</div>
            <div class="item_tzg">Keep an eye on your inbox — and check your spam folder if you don't hear from us.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== WHY LUMA ===================== -->
<section class="contact_why dark_bg overflow-hidden">
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center" data-show-down>What Happens After You Reach Out</h2>
    </div>
    <div class="wrap_why_work grid grid-cols-3" style="--cols:3;">
      <div class="item_why_work text-center" data-show-down data-delay=".1">
        <div class="icon_why_work"><img src="/img/icons/why_work_1.svg" alt="" loading="lazy"></div>
        <div class="title_why_work">Same-Day Response</div>
        <div class="descr_why_work">We reply to every inquiry the same business day between 9 AM and 6 PM EST. You'll hear from Ivan directly — not a sales rep or an account manager.</div>
      </div>
      <div class="item_why_work text-center" data-show-down data-delay=".15">
        <div class="icon_why_work"><img src="/img/icons/why_work_4.svg" alt="" loading="lazy"></div>
        <div class="title_why_work">Discovery Call</div>
        <div class="descr_why_work">If the project sounds like a good fit, we'll schedule a 30-minute discovery call to understand your goals, timeline, and budget before putting anything in writing.</div>
      </div>
      <div class="item_why_work text-center" data-show-down data-delay=".2">
        <div class="icon_why_work"><img src="/img/icons/why_work_5.svg" alt="" loading="lazy"></div>
        <div class="title_why_work">Clear Proposal</div>
        <div class="descr_why_work">After the call, we send a written proposal with scope, timeline, and pricing clearly defined — no vague retainers or hidden costs to untangle later.</div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== RELATED LINKS ===================== -->
<section class="contact_related overflow-hidden">
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center" data-show-down>Explore Our Services</h2>
    </div>
    <div class="about_services_grid grid grid-cols-3" data-show-down>
      <a href="/managed-websites/" class="about_service_card">
        <div class="about_service_card__name">Managed Websites</div>
        <div class="about_service_card__desc">Custom sites built and managed for local businesses — no upfront cost.</div>
        <span class="about_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="/services/seo-services/" class="about_service_card">
        <div class="about_service_card__name">SEO Services</div>
        <div class="about_service_card__desc">On-page, technical, and local SEO for Maine businesses.</div>
        <span class="about_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="/services/ux-audits/" class="about_service_card">
        <div class="about_service_card__name">UX Audits</div>
        <div class="about_service_card__desc">Find what's hurting your conversions and get a plan to fix it.</div>
        <span class="about_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
    </div>
  </div>
</section>

</PageLayout>

<script define:vars={{ RECAPTCHA_SITE_KEY }}>
  const form = document.getElementById('contact_page_form_el');
  const formContainer = document.getElementById('contact_page_form');
  const thanksContainer = document.getElementById('contact_page_thanks');

  if (!form) throw new Error('Contact form not found');

  const nameEl = form.querySelector('.name');
  const emailEl = form.querySelector('.email');
  const companyEl = form.querySelector('.company');
  const messageEl = form.querySelector('.message');

  const showError = (input, message) => {
    const field = input.parentElement;
    field.classList.remove('success');
    field.classList.add('error');
    const err = field.querySelector('.error_message');
    if (err) err.textContent = message;
  };

  const showSuccess = (input) => {
    const field = input.parentElement;
    field.classList.remove('error');
    field.classList.add('success');
    const err = field.querySelector('.error_message');
    if (err) err.textContent = '';
  };

  const checkName = () => {
    const v = nameEl.value.trim();
    if (!v) { showError(nameEl, 'Name cannot be blank.'); return false; }
    if (v.length < 2 || v.length > 50) { showError(nameEl, 'Name must be between 2 and 50 characters.'); return false; }
    showSuccess(nameEl); return true;
  };

  const checkEmail = () => {
    const v = emailEl.value.trim();
    if (!v) { showError(emailEl, 'Email cannot be blank.'); return false; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) { showError(emailEl, 'Please enter a valid email address.'); return false; }
    showSuccess(emailEl); return true;
  };

  const checkCompany = () => {
    const v = companyEl.value.trim();
    if (!v) { showError(companyEl, 'Business name is required.'); return false; }
    showSuccess(companyEl); return true;
  };

  const checkMessage = () => {
    const v = messageEl.value.trim();
    if (!v || v.length < 10) { showError(messageEl, 'Please tell us a bit about your project.'); return false; }
    showSuccess(messageEl); return true;
  };

  const debounce = (fn, delay = 400) => {
    let id;
    return (...args) => { clearTimeout(id); id = setTimeout(() => fn(...args), delay); };
  };

  form.addEventListener('input', debounce((e) => {
    const t = e.target;
    if (t.classList.contains('name')) checkName();
    else if (t.classList.contains('email')) checkEmail();
    else if (t.classList.contains('company')) checkCompany();
    else if (t.classList.contains('message')) checkMessage();
  }));

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!checkName() || !checkEmail() || !checkCompany() || !checkMessage()) return;

    const submitBtn = form.querySelector('.submit_form_page');
    submitBtn?.classList.add('loading');

    try {
      const token = await new Promise((resolve) => {
        window.grecaptcha.ready(() => {
          window.grecaptcha.execute(RECAPTCHA_SITE_KEY, { action: 'contact_page' }).then(resolve);
        });
      });

      const res = await fetch('/api/contact-page/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: nameEl.value.trim(),
          email: emailEl.value.trim(),
          company: companyEl.value.trim(),
          message: messageEl.value.trim(),
          recaptchaToken: token,
        }),
      });

      if (!res.ok) throw new Error('Server error');

      if (formContainer) formContainer.classList.add('hidden');
      if (thanksContainer) thanksContainer.classList.remove('hidden');
    } catch {
      submitBtn?.classList.remove('loading');
    }
  });
</script>

<style>
  .breadcrumb_wrap {
    padding: 16px 0;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }

  .breadcrumb__item::after {
    content: '/';
    margin-left: 8px;
    color: rgba(255,255,255,0.25);
  }

  .breadcrumb__item:last-child::after { display: none; }

  .breadcrumb__link {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb__link:hover { color: #fff; }

  .contact_hero {
    padding: 80px 0;
  }

  .contact_hero__inner {
    gap: 80px;
    align-items: flex-start;
  }

  .contact_h1 {
    font-size: clamp(32px, 5vw, 52px);
    margin-bottom: 20px;
    text-align: left;
  }

  .contact_intro {
    font-size: 16px;
    line-height: 28px;
    color: rgba(255,255,255,0.7);
    margin-bottom: 40px;
  }

  .contact_trust_list {
    list-style: none;
    margin: 0 0 36px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .contact_trust_item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 16px;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
  }

  .contact_trust_check {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: flex;
  }

  .contact_trust_check svg {
    width: 20px;
    height: 20px;
  }

  .contact_direct {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px 20px 20px 18px;
    border-left: 2px solid rgba(139, 92, 246, 0.35);
    background: rgba(139, 92, 246, 0.05);
    border-radius: 0 6px 6px 0;
  }

  .contact_direct_row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .contact_direct_icon {
    display: flex;
    align-items: center;
    color: #8B5CF6;
    flex-shrink: 0;
  }

  .contact_direct_icon svg {
    width: 16px;
    height: 16px;
  }

  .contact_direct_link {
    font-size: 15px;
    color: #fff;
    text-decoration: none;
    transition: color 0.2s;
  }

  .contact_direct_link:hover {
    color: rgba(255,255,255,0.75);
  }

  .contact_direct_row:hover .contact_direct_icon {
    color: #c4b5fd;
  }

  .contact_form_wrap {
    position: relative;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    padding: 40px;
  }

  .contact_form_cube {
    position: absolute;
    top: -44px;
    right: -20px;
    width: 80px;
    height: auto;
    z-index: 2;
    pointer-events: none;
  }

  /* Match managed-websites form field style */
  .contact_form_wrap .form_control {
    font-size: 15px;
    background: transparent;
  }

  .contact_form_wrap .row_form_inp {
    margin-bottom: 36px;
  }

  .contact_form_wrap .row_form_inp.grid {
    grid-column-gap: 24px;
  }

  .contact_thanks {
    text-align: center;
    padding: 40px 0;
  }

  .contact_why {
    padding: 80px 0;
  }

  .contact_related {
    padding: 80px 0;
  }

  .about_services_grid {
    gap: 16px;
    margin-top: 16px;
  }

  .about_service_card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.25s, background 0.25s;
  }

  .about_service_card:hover {
    border-color: rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.03);
  }

  .about_service_card__name {
    font-size: 16px;
    font-weight: 600;
    color: #fff;
  }

  .about_service_card__desc {
    font-size: 14px;
    line-height: 22px;
    color: rgba(255,255,255,0.5);
    flex: 1;
  }

  .about_service_card__icon {
    display: flex;
    align-items: center;
    color: #8B5CF6;
    margin-bottom: 4px;
  }

  .about_service_card__icon svg {
    width: 22px;
    height: 22px;
  }

  .about_service_card__arrow {
    display: flex;
    align-items: center;
    color: #FFFC10;
    margin-top: 8px;
  }

  .about_service_card__arrow svg {
    width: 18px;
    height: 18px;
  }

  textarea.form_control {
    resize: vertical;
    min-height: 120px;
  }

  @media (max-width: 900px) {
    .contact_hero__inner {
      grid-template-columns: 1fr !important;
      gap: 48px;
    }

    .contact_form_wrap {
      padding: 28px 20px;
    }
  }

  @media (max-width: 600px) {
    .about_services_grid {
      grid-template-columns: 1fr !important;
    }

    .contact_hero {
      padding: 48px 0;
    }
  }
</style>
