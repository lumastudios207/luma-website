      <div class="item_quote_go">
        <div class="icon_quote" item-class-toggle>
          <svg width="35" height="27" viewBox="0 0 35 27" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14.359 0C4.88604 0.886617 0 6.00929 0 14.6784V26.5H14.9573V13.1022H9.27351C9.27351 9.16171 10.6695 7.19145 14.359 6.30483V0ZM34.4017 0C24.9288 0.886617 20.0427 6.00929 20.0427 14.6784V26.5H35V13.1022H29.3162C29.3162 9.16171 30.7123 7.19145 34.4017 6.30483V0Z" fill="white" fill-opacity="0.4"/></svg>
