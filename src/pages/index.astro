---
import PageLayout from '../layouts/PageLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      name: 'Luma Studios',
      url: 'https://lumastudios.co',
      description: 'On-demand design agency helping startups and marketing agencies with graphic design, web design, brand identity, and more.',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '63 Federal Street',
        addressLocality: 'Portland',
        addressRegion: 'ME',
        postalCode: '04101',
        addressCountry: 'US',
      },
    },
    {
      '@type': 'WebSite',
      name: 'Luma Studios',
      url: 'https://lumastudios.co',
    },
  ],
};
---

<PageLayout
  title="Marketing Design Agency - Luma Studios"
  description="Our design studio helps startups and marketing agencies with a wide range of graphic and web design services."
  canonicalUrl="https://lumastudios.co/"
  ogUrl="https://lumastudios.co/"
  {jsonLd}
>

<!-- ===================== HERO ===================== -->
<section class="home_first" first-load-delay>
