      <div class="item_im_gri" data-show-down-mobile data-delay=".1">
        <a href="/constructo" class="link_project">
          <img class="img-responsive" src="/img/home_img_3.webp" alt="Constructo project">
        </a>
      </div>
    </div>
    <div class="trusted text-center">
      <div class="title_trusted">Trusted by</div>
      <div class="wrap_trusted">
        <div class="item_trust"><div class="in_to_trust flex items-center justify-center"><img src="/img/logos/client_1.svg" alt="Client"></div></div>
        <div class="item_trust"><div class="in_to_trust flex items-center justify-center"><img src="/img/logos/client_2.svg" alt="Client"></div></div>
        <div class="item_trust"><div class="in_to_trust flex items-center justify-center"><img src="/img/logos/client_3.svg" alt="Client"></div></div>
        <div class="item_trust"><div class="in_to_trust flex items-center justify-center"><img src="/img/logos/client_4.svg" alt="Client"></div></div>
        <div class="item_trust"><div class="in_to_trust flex items-center justify-center"><img src="/img/logos/client_5.svg" alt="Client"></div></div>
      </div>
    </div>
  </div>
</section>

