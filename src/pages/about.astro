---
import PageLayout from '../layouts/PageLayout.astro';
import { site } from '../data/site';
import { icons } from '../components/icons/icons';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'AboutPage',
      name: 'About Luma Studios — Web Design & Marketing Agency in Portland, Maine',
      url: 'https://lumastudios.co/about/',
      description:
        'Luma Studios is a design and web agency founded by Ivan Annikov in Portland, Maine. We build websites, run local SEO, and set up marketing systems for local businesses across the US.',
    },
    {
      '@type': 'Person',
      '@id': 'https://lumastudios.co/about/#ivan-annikov',
      name: 'Ivan Annikov',
      jobTitle: 'Founder & Lead Designer',
      worksFor: {
        '@type': 'ProfessionalService',
        name: 'Luma Studios',
        url: 'https://lumastudios.co',
      },
      url: 'https://lumastudios.co/about/',
      image: 'https://lumastudios.co/img/ivan.webp',
    },
    {
      '@type': 'ProfessionalService',
      name: 'Luma Studios',
      url: 'https://lumastudios.co',
      foundingDate: '2020',
      founder: {
        '@type': 'Person',
        name: 'Ivan Annikov',
        url: 'https://lumastudios.co/about/',
      },
      address: {
        '@type': 'PostalAddress',
        streetAddress: '63 Federal Street',
        addressLocality: 'Portland',
        addressRegion: 'ME',
        postalCode: '04101',
        addressCountry: 'US',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lumastudios.co/' },
        { '@type': 'ListItem', position: 2, name: 'About', item: 'https://lumastudios.co/about/' },
      ],
    },
  ],
};
---

<PageLayout
  title="About Luma Studios | Web Design Agency Portland Maine"
  description="Luma Studios is a design and web agency based in Portland, Maine, founded by Ivan Annikov. We build websites, run local SEO, and set up marketing systems for local businesses across the US."
  canonicalUrl="https://lumastudios.co/about/"
  ogUrl="https://lumastudios.co/about/"
  {jsonLd}
>

<!-- ===================== BREADCRUMB ===================== -->
<div class="breadcrumb_wrap">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="/" class="breadcrumb__link">Home</a></li>
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">About</li>
      </ol>
    </nav>
  </div>
</div>

<!-- ===================== HERO ===================== -->
<section class="about_hero" first-load-delay>
  <div class="container">
    <div class="about_hero__inner">
      <h1 class="heading_home about_h1">Web Design & Marketing Studio<br><span class="blue_color">in Portland, Maine</span></h1>
      <p class="descr_home_fir about_hero__sub">
        Luma Studios builds and manages the complete digital presence for local businesses — websites, SEO, marketing automation, and brand identity. We bring the same level of craft and strategic thinking we developed working with tech companies to businesses that have never had access to it.
      </p>
    </div>
  </div>
</section>

<!-- ===================== FOUNDER ===================== -->
<section class="about_founder dark_bg overflow-hidden">
  <div class="container">
    <div class="about_founder__inner grid grid-cols-2">
      <div class="about_founder__photo">
        <div class="about_founder__img_wrap">
          <img
            src="/img/ivan.webp"
            alt="Ivan Annikov — Founder & Lead Designer, Luma Studios"
            class="about_founder__img"
            width="520"
            height="560"
            loading="eager"
          >
        </div>
      </div>
      <div class="about_founder__bio" data-show-down>
        <div class="about_founder__label">Founder</div>
        <h2 class="about_founder__name">Ivan Annikov</h2>
        <div class="about_founder__title_line">Founder & Lead Designer, Luma Studios</div>
        <div class="about_founder__text">
          <p>Ivan Annikov founded Luma Studios in 2020 after nearly a decade in digital marketing design for technology companies. His background spans marketing websites, landing pages, pitch decks, sales materials, and advertising campaigns — work done for startups at every stage, from pre-launch to post-Series B.</p>
          <p>Before building Luma Studios into a full-service local agency, Ivan worked as a fractional UX/UI designer embedded in tech startup product teams. That experience — designing the actual software products that drove revenue — gives him a level of product thinking that most design shops don't bring to client work.</p>
          <p>Today, Ivan runs Luma Studios out of Portland, Maine, working directly with local business owners across the US. Every project runs through him.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== KEY RESULT ===================== -->
<section class="about_result overflow-hidden">
  <div class="container">
    <div class="about_result__inner">
      <div class="about_result__label" data-show-down>Case Study Highlight</div>
      <h2 class="title_section about_result__title" data-show-down>Helping build a compliance startup into an industry leader</h2>
      <div class="about_result__body" data-show-down>
        <p>One of Ivan's longest design partnerships was with Secureframe, a San Francisco-based compliance automation company. He joined the team when they had four employees and worked directly with the CEO for two and a half years — leading UX/UI design for their compliance web application, building the brand identity from the ground up, and designing two complete versions of their marketing website.</p>
        <p>During that collaboration, Secureframe grew to roughly 200 people and raised approximately $100 million in funding. The marketing site generated hundreds of new enterprise customer sign-ups. The work covered everything from the product interface to billboard campaigns along Highway 101 in San Francisco.</p>
        <p>That depth of experience — designing for a fast-growing product used by thousands of enterprise customers — shapes how Luma Studios approaches every engagement, regardless of scale.</p>
      </div>
      <div class="about_result__stats" data-show-down>
        <div class="about_result__stat">
          <div class="about_result__stat_value">2.5 <span>yrs</span></div>
          <div class="about_result__stat_label">Direct collaboration with Secureframe's founding team</div>
        </div>
        <div class="about_result__stat">
          <div class="about_result__stat_value">~200</div>
          <div class="about_result__stat_label">Employees when the collaboration concluded</div>
        </div>
        <div class="about_result__stat">
          <div class="about_result__stat_value">~$100M</div>
          <div class="about_result__stat_label">In funding raised during the engagement</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== SERVICES ===================== -->
<section class="about_expertise dark_bg overflow-hidden">
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center" data-show-down>What We Do</h2>
      <div class="description_section text-center" data-show-down>
        A full set of services for local businesses that need more than a template and a disappearing vendor.
      </div>
    </div>
    <div class="about_services_grid grid grid-cols-3" data-show-down>
      <a href="/managed-websites" class="about_service_card">
        <div class="about_service_card__name">Managed Websites</div>
        <div class="about_service_card__desc">Custom websites built, hosted, and fully managed — no upfront cost, no technical headaches on your end.</div>
        <span class="about_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="/services/seo-services" class="about_service_card">
        <div class="about_service_card__name">Local SEO</div>
        <div class="about_service_card__desc">Technical, on-page, and AI-era search optimization so local customers find you before they find your competition.</div>
        <span class="about_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="/branding-projects" class="about_service_card">
        <div class="about_service_card__name">Brand Identity</div>
        <div class="about_service_card__desc">Logo, color system, typography, and brand guidelines that give your business a clear, consistent visual language.</div>
        <span class="about_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="/services/website-design" class="about_service_card">
        <div class="about_service_card__name">Website Design</div>
        <div class="about_service_card__desc">High-fidelity design built for clarity and conversion — for businesses that need more than a page builder can deliver.</div>
        <span class="about_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="/services/web-development" class="about_service_card">
        <div class="about_service_card__name">Web Development</div>
        <div class="about_service_card__desc">Performance-focused development on Astro and Tailwind. Fast load times, clean code, and integrations that work reliably.</div>
        <span class="about_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
      <a href="/contact" class="about_service_card">
        <div class="about_service_card__name">Marketing Automation</div>
        <div class="about_service_card__desc">CRM setup, sales pipeline configuration, lead capture, and nurturing — so new contacts don't fall through the cracks.</div>
        <span class="about_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
      </a>
    </div>
  </div>
</section>

<!-- ===================== CTA ===================== -->
<section class="about_cta overflow-hidden">
  <div class="container">
    <div class="about_cta__inner text-center" data-show-down>
      <h2 class="title_section">Ready to work together?</h2>
      <p class="about_cta__sub">
        Book a free 30-minute call and we'll take an honest look at your current digital presence — and tell you exactly what we'd do to improve it.
      </p>
      <div class="about_cta__btns">
        <a href="https://calendly.com/iannikov/luma-design" class="btn_anim" target="_blank" rel="noopener noreferrer">
          <span class="default_btn_bg"></span>
          <span class="cb-btn_cta-title"><span data-text="Book a Free Call">Book a Free Call</span></span>
          <span class="cb-btn_cta-ripple"><span style="background-color: #212121;"></span></span>
        </a>
        <a href="/contact" class="btn_anim outline">
          <span class="default_btn_bg"></span>
          <span class="cb-btn_cta-title"><span data-text="Send a Message">Send a Message</span></span>
          <span class="cb-btn_cta-ripple"><span style="background-color: #FFFC10;"></span></span>
        </a>
      </div>
    </div>
  </div>
</section>

</PageLayout>

<style>
  /* ── Breadcrumb ──────────────────────────────────────── */
  .breadcrumb_wrap { padding: 16px 0; border-top: 1px solid rgba(255,255,255,0.07); }
  .breadcrumb__list { display: flex; align-items: center; gap: 8px; list-style: none; margin: 0; padding: 0; font-size: 13px; color: rgba(255,255,255,0.4); }
  .breadcrumb__item::after { content: '/'; margin-left: 8px; color: rgba(255,255,255,0.25); }
  .breadcrumb__item:last-child::after { display: none; }
  .breadcrumb__link { color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.2s; }
  .breadcrumb__link:hover { color: #fff; }

  /* ── Hero ─────────────────────────────────────────────── */
  .about_hero { padding: 80px 0 64px; }
  .about_hero__inner { max-width: 760px; }
  .about_h1 { font-size: clamp(32px, 5vw, 56px); margin-bottom: 24px; }
  .about_hero__sub { font-size: 18px; line-height: 32px; max-width: 680px; }

  /* ── Founder ──────────────────────────────────────────── */
  .about_founder { padding: 80px 0; }
  .about_founder__inner { gap: 72px; align-items: flex-start; }
  .about_founder__img_wrap { border-radius: 6px; overflow: hidden; background: rgba(255,255,255,0.04); }
  .about_founder__img { display: block; width: 100%; height: auto; object-fit: cover; }
  .about_founder__label { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #FFFC10; margin-bottom: 12px; }
  .about_founder__name { font-size: clamp(28px, 3.5vw, 40px); font-weight: 600; color: #fff; margin-bottom: 6px; line-height: 1.15; font-family: 'Maison Neue', sans-serif; }
  .about_founder__title_line { font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.4); letter-spacing: 0.02em; margin-bottom: 32px; }
  .about_founder__text p { font-size: 16px; line-height: 28px; color: rgba(255,255,255,0.7); margin-bottom: 18px; }
  .about_founder__text p:last-child { margin-bottom: 0; }

  /* ── Key Result ───────────────────────────────────────── */
  .about_result { padding: 80px 0; }
  .about_result__inner { max-width: 800px; margin: 0 auto; }
  .about_result__label { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 16px; }
  .about_result__title { text-align: left; margin-bottom: 28px; }
  .about_result__body p { font-size: 16px; line-height: 28px; color: rgba(255,255,255,0.7); margin-bottom: 18px; }
  .about_result__body p:last-child { margin-bottom: 0; }

  .about_result__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
    padding-top: 48px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .about_result__stat_value { font-size: 40px; font-weight: 600; color: #FFFC10; line-height: 1; margin-bottom: 10px; font-family: 'Maison Neue', sans-serif; }
  .about_result__stat_value span { font-size: 22px; }
  .about_result__stat_label { font-size: 13px; line-height: 20px; color: rgba(255,255,255,0.5); }

  /* ── Services ─────────────────────────────────────────── */
  .about_expertise { padding: 80px 0; }
  .about_services_grid { gap: 16px; margin-top: 16px; }
  .about_service_card { display: flex; flex-direction: column; gap: 8px; padding: 24px; border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; text-decoration: none; transition: border-color 0.25s, background 0.25s; }
  .about_service_card:hover { border-color: rgba(255,255,255,0.25); background: rgba(255,255,255,0.03); }
  .about_service_card__name { font-size: 16px; font-weight: 600; color: #fff; }
  .about_service_card__desc { font-size: 14px; line-height: 22px; color: rgba(255,255,255,0.5); flex: 1; }
  .about_service_card__arrow { display: flex; align-items: center; color: #FFFC10; margin-top: 8px; }
  .about_service_card__arrow svg { width: 18px; height: 18px; }

  /* ── CTA ──────────────────────────────────────────────── */
  .about_cta { padding: 96px 0; }
  .about_cta__inner { max-width: 560px; margin: 0 auto; }
  .about_cta__sub { font-size: 16px; line-height: 28px; color: rgba(255,255,255,0.65); margin: 16px 0 32px; }
  .about_cta__btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 900px) {
    .about_founder__inner { grid-template-columns: 1fr !important; gap: 40px; }
    .about_result__stats { grid-template-columns: 1fr 1fr; }
    .about_services_grid { grid-template-columns: 1fr 1fr !important; }
  }

  @media (max-width: 600px) {
    .about_hero { padding: 48px 0 40px; }
    .about_founder, .about_result, .about_expertise, .about_cta { padding: 64px 0; }
    .about_result__stats { grid-template-columns: 1fr; }
    .about_services_grid { grid-template-columns: 1fr !important; }
  }
</style>
