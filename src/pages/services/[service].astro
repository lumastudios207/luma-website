---
import PageLayout from '../../layouts/PageLayout.astro';
import { services, dynamicServiceSlugs, type Service } from '../../data/services';
import { icons } from '../../components/icons/icons';

export function getStaticPaths() {
  return dynamicServiceSlugs.map((slug) => ({ params: { service: slug } }));
}

const { service: slug } = Astro.params;
const svc = services.find((s) => s.slug === slug) as Service;

if (!svc) {
  return Astro.redirect('/404');
}

const canonicalUrl = `https://lumastudios.co/services/${svc.slug}`;

// Related service objects (up to 3, excluding current)
const relatedSvcs = services
  .filter((s) => svc.relatedServices.includes(s.slug))
  .slice(0, 3);

// Determine href for related services (managed-websites and branding-projects have custom URLs)
function serviceHref(s: Service): string {
  if (s.slug === 'managed-websites') return '/managed-websites';
  if (s.slug === 'brand-identity') return '/branding-projects';
  return `/services/${s.slug}`;
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: svc.name,
      description: svc.description,
      url: canonicalUrl,
      provider: {
        '@type': 'ProfessionalService',
        name: 'Luma Studios',
        url: 'https://lumastudios.co',
        address: {
          '@type': 'PostalAddress',
          streetAddress: '63 Federal Street',
          addressLocality: 'Portland',
          addressRegion: 'ME',
          postalCode: '04101',
          addressCountry: 'US',
        },
      },
      areaServed: { '@type': 'Country', name: 'United States' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: svc.faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lumastudios.co/' },
        { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://lumastudios.co/services' },
        { '@type': 'ListItem', position: 3, name: svc.name, item: canonicalUrl },
      ],
    },
  ],
};
---

<PageLayout
  title={svc.metaTitle}
  description={svc.metaDescription}
  canonicalUrl={canonicalUrl}
  ogUrl={canonicalUrl}
  {jsonLd}
>

<!-- ===================== BREADCRUMB ===================== -->
<div class="breadcrumb_wrap">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="/" class="breadcrumb__link">Home</a></li>
        <li class="breadcrumb__item"><a href="/services" class="breadcrumb__link">Services</a></li>
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{svc.name}</li>
      </ol>
    </nav>
  </div>
</div>

<!-- ===================== HERO ===================== -->
<section class="service_hero" first-load-delay>
  <div class="container">
    <div class="service_hero__inner">
      <div class="service_hero__text">
        <h1 class="service_hero__h1">{svc.heroHeading}</h1>
        <p class="service_hero__sub">{svc.heroSubheading}</p>
        <div class="service_hero__ctas">
          <a href="#" class="btn_anim outline" data-popup-show>
            <span class="default_btn_bg"></span>
            <span class="cb-btn_cta-title"><span data-text="Get Pricing">Get Pricing</span></span>
            <span class="cb-btn_cta-ripple"><span style="background-color: #FFFC10;"></span></span>
          </a>
          <a href="https://calendly.com/iannikov/luma-design" class="btn_anim" target="_blank" rel="noopener noreferrer">
            <span class="default_btn_bg"></span>
            <span class="cb-btn_cta-title"><span data-text="Book a Call">Book a Call</span></span>
            <span class="cb-btn_cta-ripple"><span style="background-color: #212121;"></span></span>
          </a>
        </div>
      </div>
      <div class="service_hero__image">
        <div class="service_img_placeholder">
          <img
            src={`/img/services/${svc.slug}-hero.svg`}
            alt={svc.name}
            class="hero_placeholder_svg"
            width="580"
            height="400"
            loading="eager"
          >
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== FEATURES ===================== -->
<section class="service_features dark_bg overflow-hidden">
  {svc.slug === 'seo-services' && (
    <div class="svc_feat_deco" aria-hidden="true"></div>
  )}
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center">What's Included</h2>
      <div class="description_section text-center">
        Everything you get when you work with Luma Studios on {svc.slug === 'seo-services' ? svc.name : svc.name.toLowerCase()}.
      </div>
    </div>
    <div class={`service_features_grid grid grid-cols-3${svc.slug === 'seo-services' ? ' seo_features_grid' : ''}`}>
      {svc.slug === 'seo-services' && (
        <img src="/img/cube_3d.webp" alt="" class="svc_feat_cube" width="70" aria-hidden="true" loading="lazy">
      )}
      {svc.features.map((feat, i) => (
        <div class="service_feature_card">
          <div class="service_feature_icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M20 6L9 17L4 12" stroke="#FFFC10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="service_feature_title">{feat.title}</div>
          <div class="service_feature_desc">{feat.description}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===================== PROCESS ===================== -->
<section class="service_process overflow-hidden">
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center">How It Works</h2>
      <div class="description_section text-center">
        A clear, structured process so you always know where your project stands.
      </div>
    </div>
    <div class="service_process_steps">
      {svc.process.map((step, i) => (
        <div class="service_process_step">
          <div class="service_process_step__num">0{step.step}</div>
          <div class="service_process_step__body">
            <div class="service_process_step__title">{step.title}</div>
            <div class="service_process_step__desc">{step.description}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===================== CTA BANNER ===================== -->
<section class="service_cta_banner dark_bg overflow-hidden">
  <div class="container">
    <div class="service_cta_banner__inner text-center">
      <h2 class="service_cta_banner__title">Ready to Get Started?</h2>
      <p class="service_cta_banner__sub">
        Book a free 30-minute call and we'll talk through your project, timeline, and budget with no obligation.
      </p>
      <div class="service_cta_banner__btns">
        <a href="https://calendly.com/iannikov/luma-design" class="btn_anim" target="_blank" rel="noopener noreferrer">
          <span class="default_btn_bg"></span>
          <span class="cb-btn_cta-title"><span data-text="Book a Free Call">Book a Free Call</span></span>
          <span class="cb-btn_cta-ripple"><span style="background-color: #212121;"></span></span>
        </a>
        <a href="/contact" class="btn_anim outline">
          <span class="default_btn_bg"></span>
          <span class="cb-btn_cta-title"><span data-text="Send Us a Message">Send Us a Message</span></span>
          <span class="cb-btn_cta-ripple"><span style="background-color: #FFFC10;"></span></span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===================== FAQs ===================== -->
<section class="faqs overflow-hidden">
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center">Frequently Asked Questions</h2>
    </div>
    <div class="wrap_faqs mx-auto js-accordion">
      {svc.faqs.map((faq) => (
        <div class="item_faq js-accordion__group">
          <div class="faq_heading js-accordion__menu">
            {faq.question}
            <span class="arrow_toggle"></span>
          </div>
          <div class="descr_item_faq js-accordion__content">
            <div class="in_to_descr_fq">{faq.answer}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===================== RELATED SERVICES ===================== -->
{relatedSvcs.length > 0 && (
  <section class="service_related dark_bg overflow-hidden">
    <div class="container">
      <div class="headint_sec">
        <h2 class="title_section text-center">Related Services</h2>
      </div>
      <div class="service_related_grid grid grid-cols-3">
        {relatedSvcs.map((rel) => (
          <a href={serviceHref(rel)} class="about_service_card">
            <div class="about_service_card__name">{rel.name}</div>
            <div class="about_service_card__desc">{rel.description}</div>
            <span class="about_service_card__arrow"><Fragment set:html={icons.arrowNarrowRight} /></span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}


</PageLayout>

<style>
  /* ── Breadcrumb ─────────────────────────────────────── */
  .breadcrumb_wrap {
    padding: 16px 0;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }

  .breadcrumb__item::after {
    content: '/';
    margin-left: 8px;
    color: rgba(255,255,255,0.25);
  }

  .breadcrumb__item:last-child::after { display: none; }

  .breadcrumb__link {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb__link:hover { color: #fff; }

  /* ── Hero ────────────────────────────────────────────── */
  .service_hero {
    padding: 80px 0;
  }

  .service_hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .service_hero__h1 {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 600;
    line-height: 1.15;
    color: #fff;
    margin-bottom: 20px;
    font-family: 'Maison Neue', sans-serif;
  }

  .service_hero__sub {
    font-size: 17px;
    line-height: 30px;
    color: rgba(255,255,255,0.65);
    margin-bottom: 36px;
  }

  .service_hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .service_img_placeholder {
    border-radius: 6px;
    overflow: hidden;
    background: #2a2a2a;
  }

  .hero_placeholder_svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ── Features ───────────────────────────────────────── */
  .service_features {
    padding: 80px 0;
    position: relative;
  }

  .svc_feat_deco {
    position: absolute;
    width: 600px;
    height: 600px;
    border: 1px solid #2a2a2a;
    top: 50%;
    right: -180px;
    transform: translateY(-50%) rotate(20deg);
    pointer-events: none;
    z-index: 0;
  }

  .seo_features_grid {
    position: relative;
  }

  .svc_feat_cube {
    position: absolute;
    top: -26px;
    right: -26px;
    width: 52px;
    height: auto;
    z-index: 2;
    pointer-events: none;
    animation: svc-cube-spin 12s linear infinite;
  }

  @keyframes svc-cube-spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .service_features_grid {
    gap: 20px;
    margin-top: 8px;
  }

  .service_feature_card {
    padding: 28px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.25s;
  }

  .service_feature_card:hover {
    border-color: rgba(255,255,255,0.2);
  }

  /* ── SEO page: per-card glow colors ─────────────────── */
  .seo_features_grid .service_feature_card {
    --glow: #4DD8E8;
    position: relative;
    overflow: hidden;
    background: #0e0e12;
    box-shadow: 0 0 40px #0009, 0 0 80px color-mix(in srgb, var(--glow) 15%, transparent);
    transition: border-color 0.25s, box-shadow 0.3s;
  }

  .seo_features_grid .service_feature_card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 52%;
    background: radial-gradient(ellipse 80% 60% at 50% 110%, color-mix(in srgb, var(--glow) 55%, transparent), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .seo_features_grid .service_feature_card > * {
    position: relative;
    z-index: 1;
  }

  .seo_features_grid .service_feature_card:hover {
    box-shadow: 0 0 60px #00000080, 0 0 120px color-mix(in srgb, var(--glow) 25%, transparent);
  }

  .seo_features_grid .service_feature_card:nth-child(1) { --glow: #4DD8E8; border-color: #4dd8e82e; }
  .seo_features_grid .service_feature_card:nth-child(2) { --glow: #A78BFA; border-color: #a78bfa2e; }
  .seo_features_grid .service_feature_card:nth-child(3) { --glow: #F07847; border-color: #f078472e; }
  .seo_features_grid .service_feature_card:nth-child(4) { --glow: #E84DAD; border-color: #e84dad2e; }
  .seo_features_grid .service_feature_card:nth-child(5) { --glow: #4FC3F7; border-color: #4fc3f72e; }
  .seo_features_grid .service_feature_card:nth-child(6) { --glow: #7B3FD4; border-color: #7b3fd42e; }

  .service_feature_icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,252,16,0.08);
    border-radius: 4px;
    flex-shrink: 0;
  }

  .service_feature_title {
    font-size: 16px;
    font-weight: 600;
    color: #fff;
  }

  .service_feature_desc {
    font-size: 14px;
    line-height: 24px;
    color: rgba(255,255,255,0.55);
  }

  /* ── Process ────────────────────────────────────────── */
  .service_process {
    padding: 80px 0;
  }

  .service_process_steps {
    display: flex;
    flex-direction: column;
    max-width: 700px;
    margin: 0 auto;
  }

  .service_process_step {
    display: flex;
    gap: 28px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .service_process_step:last-child {
    border-bottom: none;
  }

  .service_process_step__num {
    font-size: 32px;
    font-weight: 600;
    color: rgba(255,255,255,0.1);
    flex-shrink: 0;
    line-height: 1;
    font-family: 'Maison Neue', sans-serif;
    min-width: 48px;
  }

  .service_process_step__title {
    font-size: 17px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 8px;
  }

  .service_process_step__desc {
    font-size: 15px;
    line-height: 26px;
    color: rgba(255,255,255,0.6);
  }

  /* ── CTA Banner ─────────────────────────────────────── */
  .service_cta_banner {
    padding: 80px 0;
  }

  .service_cta_banner__inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .service_cta_banner__title {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 600;
    color: #fff;
    margin-bottom: 16px;
  }

  .service_cta_banner__sub {
    font-size: 16px;
    line-height: 28px;
    color: rgba(255,255,255,0.65);
    margin-bottom: 32px;
  }

  .service_cta_banner__btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Related services ───────────────────────────────── */
  .service_related {
    padding: 80px 0;
  }

  .service_related_grid {
    gap: 16px;
  }

  .about_service_card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.25s, background 0.25s;
  }

  .about_service_card:hover {
    border-color: rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.03);
  }

  .about_service_card__name {
    font-size: 16px;
    font-weight: 600;
    color: #fff;
  }

  .about_service_card__desc {
    font-size: 14px;
    line-height: 22px;
    color: rgba(255,255,255,0.5);
    flex: 1;
  }

  .about_service_card__arrow {
    display: flex;
    align-items: center;
    color: #FFFC10;
    margin-top: 8px;
  }

  .about_service_card__arrow svg {
    width: 18px;
    height: 18px;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .service_hero__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .service_features_grid {
      grid-template-columns: 1fr 1fr !important;
    }

    .service_related_grid {
      grid-template-columns: 1fr 1fr !important;
    }
  }

  @media (max-width: 600px) {
    .service_hero {
      padding: 48px 0;
    }

    .service_features_grid,
    .service_related_grid {
      grid-template-columns: 1fr !important;
    }

    .service_hero__ctas {
      flex-direction: column;
    }
  }
</style>
