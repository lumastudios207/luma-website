---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

const canonicalUrl = `https://lumastudios.co/blog/${post.id}/`;
const ogImage = post.data.ogImage || 'https://lumastudios.co/img/og/og_image.jpg';

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      headline: post.data.title,
      description: post.data.description,
      url: canonicalUrl,
      datePublished: post.data.publishDate.toISOString(),
      dateModified: (post.data.updatedDate || post.data.publishDate).toISOString(),
      author: {
        '@type': 'Person',
        name: post.data.author,
        url: 'https://lumastudios.co/about',
      },
      publisher: {
        '@type': 'Organization',
        name: 'Luma Studios',
        url: 'https://lumastudios.co',
        logo: {
          '@type': 'ImageObject',
          url: 'https://lumastudios.co/img/logo.svg',
        },
      },
      image: ogImage,
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lumastudios.co/' },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://lumastudios.co/blog/' },
        { '@type': 'ListItem', position: 3, name: post.data.title, item: canonicalUrl },
      ],
    },
  ],
};
---

<PageLayout
  title={post.data.metaTitle || `${post.data.title} | Luma Studios`}
  description={post.data.metaDescription || post.data.description}
  canonicalUrl={canonicalUrl}
  ogUrl={canonicalUrl}
  ogImage={ogImage}
  {jsonLd}
>

<!-- ===================== BREADCRUMB ===================== -->
<div class="breadcrumb_wrap">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb__list">
        <li class="breadcrumb__item"><a href="/" class="breadcrumb__link">Home</a></li>
        <li class="breadcrumb__item"><a href="/blog" class="breadcrumb__link">Blog</a></li>
        <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{post.data.title}</li>
      </ol>
    </nav>
  </div>
</div>

<!-- ===================== POST HEADER ===================== -->
<header class="post_header" first-load-delay>
  <div class="container">
    <div class="post_header__inner">
      <div class="post_meta">
        <span class="blog_card__category">{post.data.category}</span>
        <span class="post_meta__sep">·</span>
        <time datetime={post.data.publishDate.toISOString()} class="post_meta__date">
          {formatDate(post.data.publishDate)}
        </time>
        <span class="post_meta__sep">·</span>
        <span class="post_meta__author">By {post.data.author}</span>
      </div>
      <h1 class="post_title">{post.data.title}</h1>
      <p class="post_excerpt">{post.data.description}</p>
    </div>
  </div>
</header>

<!-- ===================== POST CONTENT ===================== -->
<article class="post_body">
  <div class="container">
    <div class="post_content">
      <Content />
    </div>

    <!-- Author box -->
    <div class="post_author_box">
      <div class="post_author_box__inner">
        <div class="post_author_avatar">
          <img src="/img/ivan.webp" alt={post.data.author} width="56" height="56" loading="lazy">
        </div>
        <div class="post_author_info">
          <div class="post_author_name">{post.data.author}</div>
          <div class="post_author_bio">Ivan Annikov is the founder of Luma Studios, a web design and marketing studio based in Portland, Maine. He works with startups and local businesses to build faster websites and stronger brands.</div>
        </div>
      </div>
    </div>
  </div>
</article>

<!-- ===================== CTA ===================== -->
<section class="post_cta dark_bg overflow-hidden">
  <div class="container">
    <div class="post_cta__inner text-center">
      <h2 class="title_section">Ready to Put This Into Practice?</h2>
      <p class="post_cta__sub">
        We build and optimize the websites we write about. Book a free call to talk through your project.
      </p>
      <div class="post_cta__btns">
        <a href="https://calendly.com/iannikov/luma-design" class="btn_anim" target="_blank" rel="noopener noreferrer">
          <span class="default_btn_bg"></span>
          <span class="cb-btn_cta-title"><span data-text="Book a Free Call">Book a Free Call</span></span>
          <span class="cb-btn_cta-ripple"><span style="background-color: #212121;"></span></span>
        </a>
        <a href="/contact" class="btn_anim outline">
          <span class="default_btn_bg"></span>
          <span class="cb-btn_cta-title"><span data-text="Get in Touch">Get in Touch</span></span>
          <span class="cb-btn_cta-ripple"><span style="background-color: #FFFC10;"></span></span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===================== RELATED SERVICES ===================== -->
<section class="post_related overflow-hidden">
  <div class="container">
    <div class="headint_sec">
      <h2 class="title_section text-center">Related Services</h2>
    </div>
    <div class="grid grid-cols-3">
      <a href="/managed-websites" class="about_service_card">
        <div class="about_service_card__name">Managed Websites</div>
        <div class="about_service_card__desc">Custom sites built and fully managed for local businesses — no upfront cost.</div>
        <span class="about_service_card__arrow">→</span>
      </a>
      <a href="/services/seo-services" class="about_service_card">
        <div class="about_service_card__name">SEO Services</div>
        <div class="about_service_card__desc">On-page, local, and technical SEO to help Maine businesses rank in search.</div>
        <span class="about_service_card__arrow">→</span>
      </a>
      <a href="/services/website-design" class="about_service_card">
        <div class="about_service_card__name">Website Design</div>
        <div class="about_service_card__desc">Custom marketing website design built for clarity and conversion.</div>
        <span class="about_service_card__arrow">→</span>
      </a>
    </div>
  </div>
</section>

</PageLayout>

<style>
  /* Breadcrumb */
  .breadcrumb_wrap {
    padding: 16px 0;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    flex-wrap: wrap;
  }

  .breadcrumb__item::after {
    content: '/';
    margin-left: 8px;
    color: rgba(255,255,255,0.25);
  }

  .breadcrumb__item:last-child::after { display: none; }

  .breadcrumb__link {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb__link:hover { color: #fff; }

  /* Post header */
  .post_header {
    padding: 64px 0 48px;
  }

  .post_header__inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .post_meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .blog_card__category {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #FFFC10;
  }

  .post_meta__sep {
    color: rgba(255,255,255,0.25);
    font-size: 12px;
  }

  .post_meta__date,
  .post_meta__author {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }

  .post_title {
    font-size: clamp(26px, 4vw, 44px);
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
    margin-bottom: 20px;
    font-family: 'Maison Neue', sans-serif;
  }

  .post_excerpt {
    font-size: 18px;
    line-height: 30px;
    color: rgba(255,255,255,0.6);
    margin: 0;
  }

  /* Post body */
  .post_body {
    padding: 48px 0 64px;
  }

  .post_content {
    max-width: 760px;
    margin: 0 auto;
    font-size: 17px;
    line-height: 30px;
    color: rgba(255,255,255,0.8);
  }

  .post_content :global(h2) {
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 600;
    color: #fff;
    margin: 48px 0 16px;
    font-family: 'Maison Neue', sans-serif;
    line-height: 1.25;
  }

  .post_content :global(h3) {
    font-size: clamp(16px, 2vw, 20px);
    font-weight: 600;
    color: #fff;
    margin: 32px 0 12px;
  }

  .post_content :global(p) {
    margin-bottom: 20px;
  }

  .post_content :global(ul),
  .post_content :global(ol) {
    margin-bottom: 24px;
    padding-left: 24px;
  }

  .post_content :global(li) {
    margin-bottom: 8px;
    color: rgba(255,255,255,0.75);
  }

  .post_content :global(strong) {
    color: #fff;
    font-weight: 600;
  }

  .post_content :global(a) {
    color: #FFFC10;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,252,16,0.3);
    transition: border-color 0.2s;
  }

  .post_content :global(a:hover) {
    border-bottom-color: #FFFC10;
  }

  .post_content :global(blockquote) {
    border-left: 3px solid #FFFC10;
    padding: 16px 24px;
    margin: 32px 0;
    background: rgba(255,255,255,0.03);
    border-radius: 0 4px 4px 0;
  }

  .post_content :global(code) {
    font-family: 'Courier New', monospace;
    font-size: 14px;
    background: rgba(255,255,255,0.08);
    padding: 2px 6px;
    border-radius: 3px;
    color: #FFFC10;
  }

  .post_content :global(pre) {
    background: rgba(255,255,255,0.06);
    border-radius: 6px;
    padding: 20px 24px;
    overflow-x: auto;
    margin: 24px 0;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .post_content :global(pre code) {
    background: none;
    padding: 0;
    color: rgba(255,255,255,0.85);
    font-size: 14px;
  }

  .post_content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 28px 0;
    font-size: 15px;
  }

  .post_content :global(th) {
    text-align: left;
    padding: 10px 16px;
    border-bottom: 2px solid rgba(255,255,255,0.15);
    color: #fff;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post_content :global(td) {
    padding: 10px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.7);
    vertical-align: top;
  }

  .post_content :global(tr:last-child td) {
    border-bottom: none;
  }

  .post_content :global(hr) {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin: 40px 0;
  }

  /* Author box */
  .post_author_box {
    max-width: 760px;
    margin: 40px auto 0;
    padding: 28px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
  }

  .post_author_box__inner {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .post_author_avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(255,255,255,0.06);
  }

  .post_author_avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post_author_name {
    font-weight: 600;
    color: #fff;
    margin-bottom: 6px;
  }

  .post_author_bio {
    font-size: 14px;
    line-height: 22px;
    color: rgba(255,255,255,0.5);
  }

  /* CTA section */
  .post_cta {
    padding: 80px 0;
  }

  .post_cta__inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .post_cta__sub {
    font-size: 16px;
    line-height: 28px;
    color: rgba(255,255,255,0.65);
    margin-bottom: 32px;
  }

  .post_cta__btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Related */
  .post_related {
    padding: 64px 0;
  }

  .post_related .grid {
    gap: 16px;
  }

  .about_service_card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.25s, background 0.25s;
  }

  .about_service_card:hover {
    border-color: rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.03);
  }

  .about_service_card__name {
    font-size: 16px;
    font-weight: 600;
    color: #fff;
  }

  .about_service_card__desc {
    font-size: 14px;
    line-height: 22px;
    color: rgba(255,255,255,0.5);
    flex: 1;
  }

  .about_service_card__arrow {
    font-size: 18px;
    color: #FFFC10;
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .post_header {
      padding: 40px 0 32px;
    }

    .post_related .grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
