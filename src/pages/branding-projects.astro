            </div>
            <div class="caption_imags">Logomark Architecture</div>
          </div>
        </div>
        <div class="item_row_webs">
          <div class="item_website_img">
            <div class="image_wb_wrap">
              <img class="img-responsive w-full" src="/img/brandings/midnight/5.webp" loading="lazy" alt="Midnight Coffee — Apparel Design">
            </div>
            <div class="caption_imags">Apparel Design</div>
          </div>
        </div>
        <div class="item_row_webs wrapper_grid_threee one-row">
          <div class="item_website_img">
            <div class="image_wb_wrap">
              <img class="img-responsive w-full" src="/img/brandings/midnight/6.webp" loading="lazy" alt="Midnight Coffee — Color Palette">
