            </div>
            <div class="item_row_webs">
              <div class="item_website_img">
                <div class="image_wb_wrap">
                  <img class="img-responsive w-full" src="/img/brandings/wild/6.webp" loading="lazy" alt="Wild Maine Seafood — Logotype on Backgrounds">
                </div>
                <div class="caption_imags">Logotype on Backgrounds</div>
              </div>
            </div>
          </div>
        </div>
        <div class="item_row_webs">
          <div class="item_website_img">
            <div class="image_wb_wrap">
              <img class="img-responsive w-full" src="/img/brandings/wild/7.webp" loading="lazy" alt="Wild Maine Seafood — Stamp Option">
