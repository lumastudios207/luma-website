---
import PageLayout from '../layouts/PageLayout.astro';
import QuoteBlock from '../components/ui/QuoteBlock.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Brand Identity Design — Luma Studios",
      "description": "Logo and brand identity design for startups and growing businesses. Color palettes, typography systems, and brand guidelines that give your business a clear, recognizable visual language.",
      "url": "https://lumastudios.co/branding-projects/",
      "provider": {
        "@type": "ProfessionalService",
        "name": "Luma Studios",
        "url": "https://lumastudios.co",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "63 Federal Street",
          "addressLocality": "Portland",
          "addressRegion": "ME",
          "postalCode": "04101",
          "addressCountry": "US"
        }
      }
    },
    {
      "@type": "CollectionPage",
      "name": "Brand Identity Design Projects — Luma Studios",
      "description": "Portfolio of brand identity design projects by Luma Studios including Wild Maine Seafood, Midnight Coffee, and BlueFly.",
      "url": "https://lumastudios.co/branding-projects/"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lumastudios.co/" },
        { "@type": "ListItem", "position": 2, "name": "Brand Identity Design", "item": "https://lumastudios.co/branding-projects/" }
      ]
    }
  ]
};
---

<PageLayout
  title="Brand Identity Portfolio | Luma Studios"
  description="Brand identity design for startups and local businesses — logos, color systems, typography, and guidelines that make your business instantly recognizable."
  canonicalUrl="https://lumastudios.co/branding-projects/"
  ogUrl="https://lumastudios.co/branding-projects/"
  ogImage="https://lumastudios.co/img/og/og_image.jpg"
  jsonLd={jsonLd}
  headerVariant="default"
>
  <!-- ===================== BREADCRUMB ===================== -->
  <div class="breadcrumb_wrap">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol class="breadcrumb__list">
          <li class="breadcrumb__item"><a href="/" class="breadcrumb__link">Home</a></li>
          <li class="breadcrumb__item"><a href="/services" class="breadcrumb__link">Services</a></li>
          <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">Brand Identity Design</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- ===================== HERO ===================== -->
  <section class="service_hero" first-load-delay>
    <div class="container">
      <div class="service_hero__inner">
        <div class="service_hero__text">
          <h1 class="service_hero__h1">Our Brand Identity Work</h1>
          <p class="service_hero__sub">At Luma, brand development isn't just a service — it's a strategic partnership. We dive deep to uncover what makes your business distinct and craft visual identities that resonate with your audience and elevate your story. From the first spark of an idea to a fully realized brand experience, we shape work that's thoughtful, purposeful, and memorable.</p>
          <div class="service_hero__ctas">
            <a href="#" class="btn_anim outline" data-popup-show>
              <span class="default_btn_bg"></span>
              <span class="cb-btn_cta-title"><span data-text="Get Pricing">Get Pricing</span></span>
              <span class="cb-btn_cta-ripple"><span style="background-color: #FFFC10;"></span></span>
            </a>
            <a href="https://calendly.com/iannikov/luma-design" class="btn_anim" target="_blank" rel="noopener noreferrer">
              <span class="default_btn_bg"></span>
              <span class="cb-btn_cta-title"><span data-text="Book a Call">Book a Call</span></span>
              <span class="cb-btn_cta-ripple"><span style="background-color: #212121;"></span></span>
            </a>
          </div>
        </div>
        <div class="service_hero__image">
          <div class="service_img_placeholder">
            <img
              src="/img/services/brand-identity-hero.svg"
              alt="Brand Identity Design — Luma Studios"
              class="hero_placeholder_svg"
              width="580"
              height="400"
              loading="eager"
            >
            <svg viewBox="0 0 580 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="hero_placeholder_svg" style="display:none">
              <rect width="580" height="400" fill="#2a2a2a" rx="6"/>
              <rect x="40" y="40" width="200" height="12" rx="6" fill="rgba(255,255,255,0.08)"/>
              <rect x="40" y="64" width="140" height="12" rx="6" fill="rgba(255,255,255,0.05)"/>
              <rect x="40" y="108" width="500" height="8" rx="4" fill="rgba(255,255,255,0.06)"/>
              <rect x="40" y="126" width="460" height="8" rx="4" fill="rgba(255,255,255,0.06)"/>
              <rect x="40" y="144" width="480" height="8" rx="4" fill="rgba(255,255,255,0.06)"/>
              <rect x="40" y="162" width="360" height="8" rx="4" fill="rgba(255,255,255,0.06)"/>
              <rect x="40" y="210" width="120" height="36" rx="4" fill="rgba(255,252,16,0.12)"/>
              <rect x="176" y="210" width="120" height="36" rx="4" fill="rgba(255,255,255,0.06)"/>
              <rect x="40" y="276" width="500" height="1" fill="rgba(255,255,255,0.06)"/>
              <rect x="40" y="300" width="140" height="8" rx="4" fill="rgba(255,255,255,0.05)"/>
              <rect x="40" y="318" width="500" height="6" rx="3" fill="rgba(255,255,255,0.04)"/>
              <rect x="40" y="334" width="440" height="6" rx="3" fill="rgba(255,255,255,0.04)"/>
              <rect x="40" y="350" width="460" height="6" rx="3" fill="rgba(255,255,255,0.04)"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wild Maine Seafood -->
