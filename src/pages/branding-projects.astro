<style>
  /* ── Breadcrumb ─────────────────────────────────────── */
  .breadcrumb_wrap {
    padding: 16px 0;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }

  .breadcrumb__item::after {
    content: '/';
    margin-left: 8px;
    color: rgba(255,255,255,0.25);
  }

  .breadcrumb__item:last-child::after { display: none; }

  .breadcrumb__link {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb__link:hover { color: #fff; }

  /* ── Hero ────────────────────────────────────────────── */
  .service_hero {
    padding: 80px 0;
  }

  .service_hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .service_hero__h1 {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 600;
    line-height: 1.15;
    color: #fff;
    margin-bottom: 20px;
    font-family: 'Maison Neue', sans-serif;
  }

  .service_hero__sub {
    font-size: 17px;
    line-height: 30px;
    color: rgba(255,255,255,0.65);
    margin-bottom: 36px;
  }

  .service_hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .service_img_placeholder {
    border-radius: 6px;
    overflow: hidden;
    background: #2a2a2a;
  }

  .hero_placeholder_svg {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 900px) {
    .service_hero__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 600px) {
    .service_hero {
      padding: 48px 0;
    }

    .service_hero__ctas {
      flex-direction: column;
    }
  }
</style>
