            </div>
            <div class="caption_imags">Baked Goods Packaging</div>
          </div>
        </div>
        <div class="item_row_webs">
          <div class="item_website_img">
            <div class="image_wb_wrap">
              <img class="img-responsive w-full" src="/img/brandings/midnight/10.webp" loading="lazy" alt="Midnight Coffee — To-Go Bag Design">
            </div>
            <div class="caption_imags">To-Go Bag Design</div>
          </div>
        </div>
        <div class="item_row_webs wrapper_grid_threee one-row">
          <div class="item_website_img">
            <div class="image_wb_wrap">
              <img class="img-responsive w-full" src="/img/brandings/midnight/11.webp" loading="lazy" alt="Midnight Coffee — Logo Variations">
            </div>
            <div class="caption_imags">Logo Variations</div>
          </div>
          <div class="item_website_img">
            <div class="image_wb_wrap">
              <img class="img-responsive w-full" src="/img/brandings/midnight/12.webp" loading="lazy" alt="Midnight Coffee — Logo Background Alternatives">
            </div>
