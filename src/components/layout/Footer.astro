---
import { site } from '../../data/site';

const year = new Date().getFullYear();

const serviceLinks = [
  { href: '/managed-websites/', label: 'Managed Websites' },
  { href: '/services/website-design/', label: 'Website Design' },
  { href: '/services/web-development/', label: 'Web Development' },
  { href: '/branding-projects/', label: 'Brand Identity' },
  { href: '/services/seo-services/', label: 'SEO Services' },
  { href: '/services/ux-audits/', label: 'UX Audits' },
  { href: '/services/ad-creative/', label: 'Ad Creative' },
];
---

<footer class="footer_go">
  <div class="wrp_foot_top">
    <div class="container">
      <div class="wrp_foot_cols grid grid-cols-3">
        <!-- Logo + tagline -->
        <div class="foot_col_brand">
          <a href="/">
            <img src="/img/logo.svg" alt="Luma Studios" loading="lazy" width="148">
          </a>
          <p class="foot_tagline">Design and web services for startups and local businesses in Portland, Maine.</p>
          <a href={site.social.dribbble} class="foot_dribbble flex items-center" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M0 12C0 9.82399 0.536016 7.81601 1.608 5.976C2.68001 4.13599 4.13602 2.68001 5.976 1.608C7.81601 0.535992 9.82402 0 12 0C14.176 0 16.184 0.535992 18.024 1.608C19.864 2.68001 21.32 4.13599 22.392 5.976C23.464 7.81601 24 9.82399 24 12C24 14.176 23.464 16.184 22.392 18.024C21.32 19.864 19.864 21.32 18.024 22.392C16.184 23.464 14.176 24 12 24C9.82402 24 7.81601 23.464 5.976 22.392C4.13602 21.32 2.68001 19.864 1.608 18.024C0.536016 16.184 0 14.176 0 12ZM1.992 12C1.992 14.496 2.832 16.696 4.512 18.6C5.28 17.096 6.49601 15.664 8.16 14.304C9.82402 12.944 11.448 12.088 13.032 11.736C12.792 11.176 12.56 10.672 12.336 10.224C9.58402 11.104 6.60802 11.544 3.408 11.544C2.784 11.544 2.32001 11.536 2.016 11.52C2.016 11.584 2.01202 11.664 2.004 11.76C1.99601 11.856 1.992 11.936 1.992 12ZM2.304 9.528C2.65601 9.55999 3.17602 9.576 3.864 9.576C6.53602 9.576 9.072 9.216 11.472 8.496C10.256 6.336 8.92001 4.536 7.464 3.096C6.20002 3.73601 5.11601 4.62401 4.212 5.76C3.30802 6.89599 2.67202 8.15201 2.304 9.528ZM5.88 19.896C7.68802 21.304 9.72802 22.008 12 22.008C13.184 22.008 14.36 21.784 15.528 21.336C15.208 18.6 14.584 15.952 13.656 13.392C12.184 13.712 10.7 14.52 9.204 15.816C7.70801 17.112 6.6 18.472 5.88 19.896ZM9.552 2.328C10.96 3.78401 12.264 5.59999 13.464 7.776C15.64 6.864 17.28 5.70401 18.384 4.296C16.528 2.76 14.4 1.992 12 1.992C11.184 1.992 10.368 2.10401 9.552 2.328ZM14.328 9.48C14.568 9.99199 14.84 10.64 15.144 11.424C16.328 11.312 17.616 11.256 19.008 11.256C20 11.256 20.984 11.28 21.96 11.328C21.832 9.15199 21.048 7.21601 19.608 5.52C18.568 7.07201 16.808 8.39201 14.328 9.48ZM15.744 13.104C16.56 15.472 17.112 17.904 17.4 20.4C18.664 19.584 19.696 18.536 20.496 17.256C21.296 15.976 21.776 14.592 21.936 13.104C20.768 13.024 19.704 12.984 18.744 12.984C17.864 12.984 16.864 13.024 15.744 13.104Z" fill="#FFFC10"/>
            </svg>
            <span>Follow us on Dribbble</span>
          </a>
        </div>

        <!-- Services links -->
        <div class="foot_col_links">
          <div class="foot_col_title">Services</div>
          <ul class="foot_links_list">
            {serviceLinks.map((link) => (
              <li><a href={link.href} class="foot_link">{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Contact info -->
        <div class="foot_col_contact">
          <div class="foot_col_title">Contact</div>
          <div class="foot_contact_item">
            <a href={`tel:${site.phonePlain}`} class="foot_link">{site.phone}</a>
          </div>

          <div class="foot_contact_item foot_address">
            <svg width="16" height="16" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M6.48711 16.94C7.92253 19.0615 10.0937 21.3591 13.0007 23.8327C15.9076 21.3591 18.0788 19.0615 19.5142 16.94C20.9496 14.8184 21.6673 12.8549 21.6673 11.0493C21.6673 8.34102 20.7961 6.18338 19.0538 4.57643C17.3114 2.96949 15.2937 2.16602 13.0007 2.16602C10.7076 2.16602 8.68989 2.96949 6.94753 4.57643C5.20516 6.18338 4.33398 8.34102 4.33398 11.0493C4.33398 12.8549 5.05169 14.8184 6.48711 16.94ZM13 13C14.6569 13 16 11.6569 16 10C16 8.34315 14.6569 7 13 7C11.3431 7 10 8.34315 10 10C10 11.6569 11.3431 13 13 13Z" fill="#979797"/>
            </svg>
            <span>{site.address.full}</span>
          </div>
          <div class="foot_contact_item">
            <a href="/contact/" class="btn_anim outline foot_cta_btn" style="font-size:13px;">
              <span class="default_btn_bg"></span>
              <span class="cb-btn_cta-title"><span data-text="Get in Touch">Get in Touch</span></span>
              <span class="cb-btn_cta-ripple"><span style="background-color: #FFFC10;"></span></span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="wrp_foot_sec">
    <div class="container">
      <div class="wrap_fo_infdf flex items-center justify-between">
        <div class="copyri_foo">
          © {year} Luma Studios, <span class="br_mob_go"></span>All Rights Reserved
          <a href="/privacy-policy/" class="link_privacy">Privacy Policy</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .wrp_foot_top {
    padding: 64px 0 48px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .wrp_foot_cols {
    gap: 48px;
    align-items: flex-start;
  }

  .foot_col_brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .foot_tagline {
    font-size: 14px;
    line-height: 22px;
    color: rgba(255,255,255,0.5);
    margin: 0;
    max-width: 220px;
  }

  .foot_dribbble {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.25s;
  }

  .foot_dribbble:hover {
    color: #fff;
  }

  .foot_col_title {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 20px;
  }

  .foot_links_list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .foot_link {
    font-size: 14px;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.25s;
  }

  .foot_link:hover {
    color: #fff;
  }

  .foot_col_contact {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .foot_col_contact .foot_col_title {
    margin-bottom: 8px;
  }

  .foot_contact_item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 14px;
    color: rgba(255,255,255,0.65);
  }

  .foot_address {
    align-items: flex-start;
  }

  .foot_address svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .foot_cta_btn {
    margin-top: 8px;
  }

  @media (max-width: 900px) {
    .wrp_foot_cols {
      grid-template-columns: 1fr 1fr !important;
    }

    .foot_col_brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .wrp_foot_cols {
      grid-template-columns: 1fr !important;
    }

    .wrp_foot_top {
      padding: 40px 0 32px;
    }
  }
</style>
