---
// client:load — handles popup show/hide, form validation, reCAPTCHA, submission
---

<script>
import gsap from 'gsap';

const RECAPTCHA_SITE_KEY = '6Led6ogsAAAAAFaFaM50DpZNy4glFZvN8fH-5yEX';

// Get Lenis from global (set by AnimationsIsland)
function getLenis() { return (window as any).__lenis; }

// =====================================================
// POPUP SHOW / HIDE
// =====================================================
document.querySelectorAll('[data-popup-show]').forEach((btn) => {
  btn.addEventListener('click', (e) => {
    e.preventDefault();
    const dialogPopup = document.querySelector('.dialog_popup');
    if (!dialogPopup) return;

    const formStep = document.getElementById('form_contact');
    const thanksStep = document.getElementById('thanks_message');
    if (formStep) formStep.classList.remove('hidden');
    if (thanksStep) thanksStep.classList.add('hidden');

    const form = document.querySelector<HTMLFormElement>('#form_contact form');
    if (form) resetFormUI(form);

    (dialogPopup as HTMLElement).scrollTo(0, 0);
    dialogPopup.classList.add('is-visible');

    gsap.from('[data-anim-popup]', { y: 10, duration: 0.6, autoAlpha: 0, stagger: 0.1, ease: 'power1.out' });

    const l = getLenis();
    if (l) l.stop();
  });
});

document.querySelectorAll('[data-popup-close]').forEach((btn) => {
  btn.addEventListener('click', (e) => {
    e.preventDefault();
    document.querySelector('.dialog_popup')?.classList.remove('is-visible');
    const l = getLenis();
    if (l) l.start();
  });
});

document.querySelector('[data-reset-form]')?.addEventListener('click', (e) => {
  e.preventDefault();
  document.getElementById('form_contact')?.classList.remove('hidden');
  document.getElementById('thanks_message')?.classList.add('hidden');
  gsap.from('[data-anim-popup]', { y: 10, duration: 0.6, autoAlpha: 0, stagger: 0.1, ease: 'power1.out' });

  const form = document.querySelector<HTMLFormElement>('#form_contact form');
  if (form) resetFormUI(form);
});

// =====================================================
// FORM VALIDATION + SUBMISSION
// =====================================================
const form = document.querySelector<HTMLFormElement>('#contact_form_el');
if (form) {
  const nameEl = form.querySelector<HTMLInputElement>('.name')!;
  const emailEl = form.querySelector<HTMLInputElement>('.email')!;
  const companyEl = form.querySelector<HTMLInputElement>('.company')!;

  const isRequired = (v: string) => v !== '';
  const isBetween = (len: number, min: number, max: number) => len >= min && len <= max;
  const isEmailValid = (email: string) =>
    /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

  const showError = (input: HTMLInputElement, message: string) => {
    form.querySelector('.submit_form')?.classList.remove('loading');
    const field = input.parentElement!;
    field.classList.remove('success');
    field.classList.add('error');
    const err = field.querySelector('.error_message');
    if (err) err.textContent = message;
  };

  const showSuccess = (input: HTMLInputElement) => {
    const field = input.parentElement!;
    field.classList.remove('error');
    field.classList.add('success');
    const err = field.querySelector('.error_message');
    if (err) err.textContent = '';
  };

  const checkName = () => {
    const name = nameEl.value.trim();
    if (!isRequired(name)) { showError(nameEl, 'Name cannot be blank.'); return false; }
    if (!isBetween(name.length, 2, 50)) { showError(nameEl, 'Name must be between 2 and 50 characters.'); return false; }
    showSuccess(nameEl); return true;
  };

  const checkEmail = () => {
    const email = emailEl.value.trim();
    if (!isRequired(email)) { showError(emailEl, 'Email cannot be blank.'); return false; }
    if (!isEmailValid(email)) { showError(emailEl, 'Email is not valid.'); return false; }
    showSuccess(emailEl); return true;
  };

  const checkCompany = () => {
    const company = companyEl.value.trim();
    if (!isRequired(company)) { showError(companyEl, 'Company cannot be blank.'); return false; }
    showSuccess(companyEl); return true;
  };

  // Live validation
  const debounce = (fn: Function, delay = 400) => {
    let id: ReturnType<typeof setTimeout>;
    return (...args: any[]) => { clearTimeout(id); id = setTimeout(() => fn(...args), delay); };
  };

  form.addEventListener('input', debounce((e: InputEvent) => {
    const target = e.target as HTMLInputElement;
    if (target.classList.contains('name')) checkName();
    else if (target.classList.contains('email')) checkEmail();
    else if (target.classList.contains('company')) checkCompany();
  }));

  // Submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('.submit_form');

    if (!checkName() || !checkEmail() || !checkCompany()) return;

    submitBtn?.classList.add('loading');

    try {
      // Get reCAPTCHA v3 token
      const token = await new Promise<string>((resolve) => {
        (window as any).grecaptcha.ready(() => {
          (window as any).grecaptcha.execute(RECAPTCHA_SITE_KEY, { action: 'contact' }).then(resolve);
        });
      });

      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: nameEl.value.trim(),
          email: emailEl.value.trim(),
          company: companyEl.value.trim(),
          recaptchaToken: token,
        }),
      });

      if (!res.ok) throw new Error('Server error');

      // Success
      document.getElementById('form_contact')?.classList.add('hidden');
      document.getElementById('thanks_message')?.classList.remove('hidden');
      gsap.from('.thansk_wrapp_go,.subtitle_formgg,.item_tzg,.wrp_ok_thanks', {
        delay: 0.2, duration: 1, y: 10, autoAlpha: 0, stagger: 0.1, ease: 'power1.out',
      });
      resetFormUI(form);
    } catch {
      submitBtn?.classList.remove('loading');
    }
  });
}

function resetFormUI(form: HTMLFormElement) {
  form.reset();
  form.querySelectorAll('.form_group').forEach((group) => {
    group.classList.remove('error', 'success');
    const err = group.querySelector('.error_message');
    if (err) err.textContent = '';
  });
  form.querySelector('.submit_form')?.classList.remove('loading');
}
</script>
